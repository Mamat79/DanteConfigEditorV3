<Window x:Class="DanteConfigEditor.ComparisonResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Comparaison XML"
        Width="1100"
        Height="650"
        MinWidth="820"
        MinHeight="480"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="SummaryTextBlock"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10" />

        <DataGrid x:Name="ComparisonGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Élément" Binding="{Binding Item}" Width="2*" />
                <DataGridTextColumn Header="Fichier ouvert" Binding="{Binding OpenValue}" Width="2*" />
                <DataGridTextColumn Header="Fichier comparé" Binding="{Binding ComparedValue}" Width="2*" />
                <DataGridTextColumn Header="État" Binding="{Binding Status}" Width="1.1*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Fermer" Padding="18,8" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
