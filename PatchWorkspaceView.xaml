<UserControl x:Class="DanteConfigEditor.PatchWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DanteConfigEditor"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             MinWidth="900">
    <UserControl.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#10141F" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#171D2B" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#202838" />
        <SolidColorBrush x:Key="TextBrush" Color="#F6F8FB" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#AAB4C5" />
        <SolidColorBrush x:Key="BorderLineBrush" Color="#334057" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2F80ED" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#1D5FB8" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="Padding" Value="0,8,0,4" />
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Padding" Value="7,5" />
        </Style>
        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Padding" Value="8,5" />
        </Style>
        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Padding" Value="8,6" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#BFDBFE" />
                    <Setter Property="Foreground" Value="#111827" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Padding" Value="7,5" />
        </Style>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
        </Style>
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,3,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="10" />
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentDarkBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="GridLinesVisibility" Value="All" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceAltBrush}" />
        </Style>
        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MatrixCellToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="automation:AutomationProperties.HelpText" Value="Cliquez pour affecter ou retirer ce patch. Maintenez et glissez pour préparer une série." />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentDarkBrush}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderLineBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock"
                               Text="Easy patch"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="IntroTextBlock"
                               Text="Préparez les affectations puis appliquez-les en une seule opération."
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>
                <TextBlock x:Name="PendingHeaderTextBlock"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,10,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel x:Name="RxDevicePanel" Grid.Column="0">
                <Label x:Name="RxDeviceLabel" Content="Machine réceptrice RX" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="PreviousRxDeviceButton"
                            Width="36"
                            MinHeight="32"
                            Padding="0"
                            Margin="0"
                            Content="←"
                            ToolTip="Machine RX précédente"
                            automation:AutomationProperties.Name="Machine RX précédente"
                            Click="PreviousRxDeviceButton_Click" />
                    <ComboBox x:Name="RxDeviceComboBox"
                              Grid.Column="1"
                              Margin="6,0"
                              automation:AutomationProperties.Name="Machine réceptrice RX"
                              SelectionChanged="RxDeviceComboBox_SelectionChanged" />
                    <Button x:Name="NextRxDeviceButton"
                            Grid.Column="2"
                            Width="36"
                            MinHeight="32"
                            Padding="0"
                            Margin="0"
                            Content="→"
                            ToolTip="Machine RX suivante"
                            automation:AutomationProperties.Name="Machine RX suivante"
                            Click="NextRxDeviceButton_Click" />
                </Grid>
            </StackPanel>
            <StackPanel x:Name="TxDevicePanel" Grid.Column="2">
                <Label x:Name="TxDeviceLabel" Content="Machine émettrice TX" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="PreviousTxDeviceButton"
                            Width="36"
                            MinHeight="32"
                            Padding="0"
                            Margin="0"
                            Content="←"
                            ToolTip="Machine TX précédente"
                            automation:AutomationProperties.Name="Machine TX précédente"
                            Click="PreviousTxDeviceButton_Click" />
                    <ComboBox x:Name="TxDeviceComboBox"
                              Grid.Column="1"
                              Margin="6,0"
                              automation:AutomationProperties.Name="Machine émettrice TX"
                              SelectionChanged="TxDeviceComboBox_SelectionChanged" />
                    <Button x:Name="NextTxDeviceButton"
                            Grid.Column="2"
                            Width="36"
                            MinHeight="32"
                            Padding="0"
                            Margin="0"
                            Content="→"
                            ToolTip="Machine TX suivante"
                            automation:AutomationProperties.Name="Machine TX suivante"
                            Click="NextTxDeviceButton_Click" />
                </Grid>
            </StackPanel>
        </Grid>

        <TabControl x:Name="PatchModeTabControl" Grid.Row="2" Margin="16,0,16,10">
            <TabItem x:Name="AssignmentTab" Header="Sélection et plage">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,0,8">
                        <Button x:Name="SelectAllRxButton"
                                DockPanel.Dock="Right"
                                Content="Tout sélectionner"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,4"
                                Margin="8,0,0,0"
                                Click="SelectAllRxButton_Click" />
                        <TextBlock x:Name="RxListHeadingTextBlock"
                                   Text="Canaux RX et source actuelle"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <ListBox x:Name="RxChannelListBox"
                             Grid.Column="0"
                             Grid.Row="1"
                             SelectionMode="Extended"
                             automation:AutomationProperties.Name="Canaux RX et source actuelle"
                             SelectionChanged="RxChannelListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Target.DanteId, StringFormat={}{0:000} - }"
                                               VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding ChannelName, Mode=OneWay}"
                                             Tag="{Binding}"
                                             Margin="2,0,4,0"
                                             Padding="2,1"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Cursor="IBeam"
                                             ToolTip="Cliquez pour renommer le canal RX ; Entrée valide, Échap annule."
                                             PreviewMouseLeftButtonDown="InlineChannelNameTextBox_PreviewMouseLeftButtonDown"
                                             LostKeyboardFocus="InlineChannelNameTextBox_LostKeyboardFocus"
                                             KeyDown="InlineChannelNameTextBox_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Setter Property="IsReadOnly" Value="True" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PatchWorkspaceView}}, Path=CanRenameChannels}" Value="True">
                                                        <Setter Property="IsReadOnly" Value="False" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SourceDisplay, StringFormat={}←  {0}}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <Thumb Grid.Column="3"
                                           Width="16"
                                           Height="20"
                                           Margin="5,0,0,0"
                                           Cursor="SizeNS"
                                           Tag="{Binding}"
                                           ToolTip="Étendre la série de noms jusqu'ici"
                                           DragStarted="ChannelSeriesThumb_DragStarted"
                                           DragCompleted="ChannelSeriesThumb_DragCompleted">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#DCE6F2" BorderBrush="#7890AC" BorderThickness="1" CornerRadius="2">
                                                    <TextBlock Text="↕" Foreground="#1F2937" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ScrollViewer Grid.Column="1"
                                  Grid.RowSpan="2"
                                  Margin="16,0"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                    <StackPanel HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                        <TextBlock x:Name="SelectionHintTextBlock"
                                   Text="Sélection"
                                   FontWeight="SemiBold"
                                   TextAlignment="Left"
                                   Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PreviewSelectionButton"
                                    Content="Prévisualiser"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="6"
                                    Margin="0,0,4,6"
                                    Click="PreviewSelectionButton_Click" />
                            <Button x:Name="ApplySelectionDirectButton"
                                    Grid.Column="1"
                                    Content="Appliquer"
                                    Padding="6"
                                    Margin="4,0,0,6"
                                    ToolTip="Applique immédiatement la sélection et les éventuels changements déjà ajoutés au lot."
                                    Click="ApplySelectionDirectButton_Click" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="RemoveSelectedRxButton"
                                    Content="Déconnecter"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="6"
                                    Margin="0,0,4,4"
                                    Click="RemoveSelectedRxButton_Click" />
                            <Button x:Name="ClearSelectionButton"
                                    Grid.Column="1"
                                    Content="Effacer la sélection"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="6"
                                    Margin="4,0,0,4"
                                    Click="ClearSelectionButton_Click" />
                        </Grid>

                        <Separator Margin="0,6" Background="{DynamicResource BorderLineBrush}" />
                        <TextBlock x:Name="RangeHeadingTextBlock"
                                   Text="Patch par plage"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,2" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="82" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Label x:Name="RangeStartRxLabel" Content="Premier RX" VerticalAlignment="Center" Padding="0,4" />
                            <ComboBox x:Name="RangeStartRxComboBox"
                                      Grid.Column="1"
                                      Margin="4,2"
                                      DisplayMemberPath="Display"
                                      SelectionChanged="RangeControl_Changed" />
                            <Label x:Name="RangeStartTxLabel" Grid.Row="1" Content="Premier TX" VerticalAlignment="Center" Padding="0,4" />
                            <ComboBox x:Name="RangeStartTxComboBox"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="4,2"
                                      DisplayMemberPath="Display"
                                      SelectionChanged="RangeControl_Changed" />
                            <Label x:Name="RangeCountLabel" Grid.Row="2" Content="Nombre" VerticalAlignment="Center" Padding="0,4" />
                            <TextBox x:Name="RangeCountTextBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="4,2"
                                     Text="1"
                                     TextChanged="RangeControl_Changed" />
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PreviewRangeButton"
                                    Content="Prévisualiser"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="6"
                                    Margin="0,0,4,0"
                                    Click="PreviewRangeButton_Click" />
                            <Button x:Name="ApplyRangeDirectButton"
                                    Grid.Column="1"
                                    Content="Appliquer"
                                    Padding="6"
                                    Margin="4,0,0,0"
                                    ToolTip="Applique immédiatement la plage et les éventuels changements déjà ajoutés au lot."
                                    Click="ApplyRangeDirectButton_Click" />
                        </Grid>
                    </StackPanel>
                    </ScrollViewer>

                    <DockPanel Grid.Column="2" Margin="0,0,0,8">
                        <Button x:Name="SelectAllTxButton"
                                DockPanel.Dock="Right"
                                Content="Tout sélectionner"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,4"
                                Margin="8,0,0,0"
                                Click="SelectAllTxButton_Click" />
                        <TextBlock x:Name="TxListHeadingTextBlock"
                                   Text="Canaux TX disponibles"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <ListBox x:Name="TxChannelListBox"
                             Grid.Column="2"
                             Grid.Row="1"
                             SelectionMode="Extended"
                             automation:AutomationProperties.Name="Canaux TX disponibles"
                             SelectionChanged="TxChannelListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Source.DanteId, StringFormat={}{0:000} - }"
                                               VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding ChannelName, Mode=OneWay}"
                                             Tag="{Binding}"
                                             Margin="2,0,0,0"
                                             Padding="2,1"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Cursor="IBeam"
                                             ToolTip="Cliquez pour renommer le canal TX ; Entrée valide, Échap annule."
                                             PreviewMouseLeftButtonDown="InlineChannelNameTextBox_PreviewMouseLeftButtonDown"
                                             LostKeyboardFocus="InlineChannelNameTextBox_LostKeyboardFocus"
                                             KeyDown="InlineChannelNameTextBox_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Setter Property="IsReadOnly" Value="True" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PatchWorkspaceView}}, Path=CanRenameChannels}" Value="True">
                                                        <Setter Property="IsReadOnly" Value="False" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                        <Setter Property="Background" Value="White" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <Thumb Grid.Column="2"
                                           Width="16"
                                           Height="20"
                                           Margin="5,0,0,0"
                                           Cursor="SizeNS"
                                           Tag="{Binding}"
                                           ToolTip="Étendre la série de noms jusqu'ici"
                                           DragStarted="ChannelSeriesThumb_DragStarted"
                                           DragCompleted="ChannelSeriesThumb_DragCompleted">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#DCE6F2" BorderBrush="#7890AC" BorderThickness="1" CornerRadius="2">
                                                    <TextBlock Text="↕" Foreground="#1F2937" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <GroupBox x:Name="PreviewGroupBox"
                              Grid.Row="2"
                              Grid.ColumnSpan="3"
                              Header="Lot prévisualisé"
                              Height="210"
                              Visibility="Collapsed"
                              Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="PreviewSummaryTextBlock"
                                       Text="Aucun changement dans le lot."
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,0,0,6" />
                            <DataGrid x:Name="PreviewGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn x:Name="PreviewTargetColumn" Header="RX cible" Binding="{Binding Target}" Width="1.2*" MinWidth="220" />
                                    <DataGridTextColumn x:Name="PreviewCurrentColumn" Header="Source actuelle" Binding="{Binding Current}" Width="1.4*" MinWidth="240" />
                                    <DataGridTextColumn x:Name="PreviewProposedColumn" Header="Nouvelle source" Binding="{Binding Proposed}" Width="1.4*" MinWidth="240" />
                                    <DataGridTextColumn x:Name="PreviewActionColumn" Header="Action" Binding="{Binding Action}" Width="130" MinWidth="110" />
                                </DataGrid.Columns>
                                <DataGrid.RowStyle>
                                    <Style TargetType="{x:Type DataGridRow}">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActionKey}" Value="Replace">
                                                <Setter Property="Background" Value="#7C2D12" />
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ActionKey}" Value="Create">
                                                <Setter Property="Background" Value="#14532D" />
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ActionKey}" Value="Remove">
                                                <Setter Property="Background" Value="#7F1D1D" />
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                            </DataGrid>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem x:Name="MatrixTab" Header="Grille de patch">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="MatrixHintTextBlock"
                               Text="RX en lignes, TX en colonnes. Cliquez ou maintenez puis glissez pour préparer plusieurs patchs."
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,0,0,8" />
                    <DataGrid x:Name="MatrixGrid"
                              Grid.Row="1"
                              RowHeight="26"
                              ColumnHeaderHeight="168"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              IsReadOnly="True"
                              FrozenColumnCount="1"
                              HeadersVisibility="Column"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              PreviewMouseLeftButtonDown="MatrixGrid_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="MatrixGrid_PreviewMouseMove"
                              PreviewMouseLeftButtonUp="MatrixGrid_PreviewMouseLeftButtonUp"
                              LostMouseCapture="MatrixGrid_LostMouseCapture">
                        <DataGrid.Resources>
                            <Style TargetType="{x:Type DataGridColumnHeader}"
                                   BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                <Setter Property="Padding" Value="1,4" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPending}" Value="True">
                                        <Setter Property="Background" Value="#5A3D08" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderLineBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="ResetPendingButton"
                            Content="Annuler les changements visuels"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="ResetPendingButton_Click" />
                    <Button x:Name="CancelButton"
                            Content="Fermer sans appliquer"
                            Style="{StaticResource SecondaryButtonStyle}"
                            IsCancel="True"
                            Click="CancelButton_Click" />
                    <Button x:Name="ApplyButton"
                            Content="Appliquer tout le lot"
                            IsDefault="True"
                            Click="ApplyButton_Click" />
                </StackPanel>
                <StackPanel VerticalAlignment="Center" Margin="0,0,18,0">
                    <TextBlock x:Name="InfoTextBlock" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock x:Name="PendingFooterTextBlock"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,3,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
