<Window x:Class="DanteConfigEditor.ImportantWarningsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Points à vérifier"
        Width="980"
        Height="560"
        MinWidth="760"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="SummaryTextBlock"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <DataGrid x:Name="WarningsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  MouseDoubleClick="WarningsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTemplateColumn x:Name="WarningColumn" Header="Alerte" Width="3*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Margin="4" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn x:Name="DeviceCountColumn" Header="Machines" Binding="{Binding DeviceCount}" Width="0.65*" />
                <DataGridTemplateColumn x:Name="AffectedDevicesColumn" Header="Machines concernées" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DevicesDisplay}" TextWrapping="Wrap" Margin="4" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CloseButton" Content="Fermer" Padding="16,8" Margin="0,0,8,0" IsCancel="True" />
            <Button x:Name="ShowDevicesButton" Content="Afficher les machines" Padding="16,8" IsDefault="True" Click="ShowDevicesButton_Click" />
        </StackPanel>
    </Grid>
</Window>
