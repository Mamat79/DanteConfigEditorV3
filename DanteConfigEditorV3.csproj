<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>DanteConfigEditorV3</AssemblyName>
    <RootNamespace>DanteConfigEditor</RootNamespace>
    <ApplicationIcon>DanteEdit.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="DanteEdit.ico" />
    <Resource Include="DanteEdit.ico" />
  </ItemGroup>
</Project>
