<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>DanteConfigEditorV3</AssemblyName>
    <RootNamespace>DanteConfigEditor</RootNamespace>
    <ApplicationIcon>DanteEdit.ico</ApplicationIcon>
    <Version>3.2.0</Version>
    <AssemblyVersion>3.2.0.0</AssemblyVersion>
    <FileVersion>3.2.0.0</FileVersion>
    <InformationalVersion>3.02-dev</InformationalVersion>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="DanteEdit.ico" />
    <Resource Include="DanteEdit.ico" />
  </ItemGroup>
</Project>
