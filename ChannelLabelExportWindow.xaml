<Window x:Class="DanteConfigEditor.ChannelLabelExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exporter des labels"
        Width="900"
        Height="650"
        MinWidth="780"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="250" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="IntroTextBlock"
                   Text="Sélectionnez les machines, les canaux TX/RX et le format. Les formats natifs sont créés directement depuis les modèles inclus dans DCE."
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <GroupBox x:Name="DevicesGroupBox" Header="Machines à exporter" Margin="0,0,12,0" Padding="8">
                <DataGrid x:Name="DevicesGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          CurrentCellChanged="DevicesGrid_CurrentCellChanged">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn x:Name="UseDeviceColumn" Header="Utiliser" Width="75">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding IsAvailable}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Click="DeviceSelectionCheckBox_Click" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn x:Name="DeviceNameColumn" Header="Machine" Binding="{Binding Name}" IsReadOnly="True" Width="*" />
                        <DataGridTextColumn Header="TX / RX" Binding="{Binding Counts}" IsReadOnly="True" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox x:Name="OptionsGroupBox" Grid.Column="1" Header="Options" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.ColumnSpan="2">
                        <Label x:Name="FormatLabel" Content="Format" />
                        <ComboBox x:Name="FormatComboBox" SelectionChanged="FormatComboBox_SelectionChanged">
                            <ComboBoxItem x:Name="JsonFormatItem" Content="JSON générique - nouveau fichier" Tag="json" />
                            <ComboBoxItem x:Name="CsvFormatItem" Content="CSV générique - nouveau fichier" Tag="csv" />
                            <ComboBoxItem x:Name="DmtDLiveFormatItem" Content="DMT XLSX - dLive" Tag="dmt-dlive" />
                            <ComboBoxItem x:Name="DmtAvantisFormatItem" Content="DMT XLSX - Avantis" Tag="dmt-avantis" />
                            <ComboBoxItem x:Name="AllenHeathDLiveFormatItem" Content="A&amp;H CSV natif - dLive" Tag="ah-dlive" />
                            <ComboBoxItem x:Name="AllenHeathAvantisFormatItem" Content="A&amp;H CSV natif - Avantis" Tag="ah-avantis" />
                            <ComboBoxItem x:Name="YamahaClFormatItem" Content="Yamaha ZIP natif - CL" Tag="yamaha-cl" />
                            <ComboBoxItem x:Name="YamahaQlFormatItem" Content="Yamaha ZIP natif - QL" Tag="yamaha-ql" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,6,6,0">
                        <Label x:Name="KindLabel" Content="Canaux" />
                        <ComboBox x:Name="KindComboBox" SelectionChanged="KindComboBox_SelectionChanged"><ComboBoxItem Content="TX"/><ComboBoxItem Content="RX"/></ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="6,6,0,0">
                        <Label x:Name="StartLabel" Content="Premier canal" />
                        <TextBox x:Name="StartTextBox" Text="1" TextChanged="OptionsChanged" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,6,0,0">
                        <Label x:Name="CountLabel" Content="Nombre (0 = tous)" />
                        <TextBox x:Name="CountTextBox" Text="0" TextChanged="OptionsChanged" />
                    </StackPanel>
                    <CheckBox x:Name="AdaptDmtCheckBox"
                              Grid.Row="3"
                              Grid.ColumnSpan="2"
                              Margin="0,10,0,0"
                              Content="Adapter au format console : ASCII et 8 caractères"
                              Checked="OptionsChanged"
                              Unchecked="OptionsChanged" />
                    <TextBlock x:Name="FormatHelpTextBlock"
                               Grid.Row="4"
                               Grid.ColumnSpan="2"
                               Margin="0,8,0,0"
                               Foreground="#475569"
                               TextWrapping="Wrap" />
                </Grid>
            </GroupBox>
        </Grid>

        <GroupBox x:Name="PreviewGroupBox" Grid.Row="2" Header="Labels exportés" Margin="0,12,0,0" Padding="8">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <TextBlock x:Name="SummaryTextBlock" Margin="0,0,0,8" TextWrapping="Wrap" />
                <DataGrid x:Name="PreviewGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="PreviewDeviceColumn" Header="Machine" Binding="{Binding DeviceName}" Width="1.2*" />
                        <DataGridTextColumn x:Name="PreviewKindColumn" Header="Type" Binding="{Binding Kind}" Width="70" />
                        <DataGridTextColumn x:Name="PreviewChannelColumn" Header="Canal" Binding="{Binding ChannelNumber}" Width="70" />
                        <DataGridTextColumn x:Name="PreviewOriginalColumn" Header="Label Dante" Binding="{Binding OriginalLabel}" Width="1.4*" />
                        <DataGridTextColumn x:Name="PreviewExportedColumn" Header="Label exporté" Binding="{Binding ExportedLabel}" Width="1.4*" />
                        <DataGridTextColumn x:Name="PreviewWarningColumn" Header="Contrôle" Binding="{Binding Warning}" Width="1.4*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="CancelButton" Content="Annuler" MinWidth="100" Margin="0,0,8,0" IsCancel="True" />
            <Button x:Name="ExportButton" Content="Exporter" MinWidth="120" IsDefault="True" Click="ExportButton_Click" />
        </StackPanel>
    </Grid>
</Window>
