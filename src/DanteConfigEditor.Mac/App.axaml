<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DanteConfigEditor.Mac.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#17191D" />
        <SolidColorBrush x:Key="PanelBrush" Color="#22252B" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#292D34" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#424853" />
        <SolidColorBrush x:Key="AppTextBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#AEB6C2" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2F80ED" />
        <SolidColorBrush x:Key="DangerBrush" Color="#E25555" />
        <SolidColorBrush x:Key="WarningBrush" Color="#E2A93B" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#48A868" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="FontFamily" Value="Inter" />
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
        </Style>
        <Style Selector="Border.atomicPanel">
            <Setter Property="Background" Value="#2B1114" />
            <Setter Property="BorderBrush" Value="#8B1A1A" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style Selector="Button.atomic">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="MinWidth" Value="176" />
            <Setter Property="MinHeight" Value="126" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid MinWidth="170" MinHeight="120" ClipToBounds="True">
                        <Ellipse Width="112"
                                 Height="112"
                                 Fill="#C8CDD3"
                                 Stroke="#4B4F55"
                                 StrokeThickness="4" />
                        <Ellipse Width="92"
                                 Height="92"
                                 Fill="#E71919"
                                 Stroke="#7F0B0B"
                                 StrokeThickness="3" />
                        <Ellipse Width="65"
                                 Height="30"
                                 Margin="0,13,0,0"
                                 VerticalAlignment="Top"
                                 Fill="#42FFFFFF"
                                 IsHitTestVisible="False" />
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False">
                            <TextBlock Text="ATOMIC"
                                       Foreground="#FFF4F4"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center" />
                            <TextBlock Text="BOMB"
                                       Foreground="White"
                                       FontSize="19"
                                       FontWeight="Black"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.atomic:pointerover">
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.atomic:pressed">
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="30" />
        </Style>
    </Application.Styles>
</Application>
