<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DanteConfigEditor.Mac.ChannelLabelExportDialog"
        Width="1040"
        Height="800"
        MinWidth="900"
        MinHeight="650"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid RowDefinitions="Auto,380,*,Auto" Margin="18" RowSpacing="12">
        <TextBlock x:Name="IntroText" TextWrapping="Wrap" />

        <Grid Grid.Row="1" ColumnDefinitions="1.3*,*" ColumnSpacing="12">
            <Border Classes="panel">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock x:Name="DevicesTitle" Classes="section" />
                    <DataGrid x:Name="DevicesGrid" Grid.Row="1" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="75">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsAvailable}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Click="DeviceSelectionCheckBox_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding Name}" IsReadOnly="True" Width="*" />
                            <DataGridTextColumn Header="TX / RX" Binding="{Binding Counts}" IsReadOnly="True" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="panel">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="7">
                    <TextBlock x:Name="OptionsTitle" Grid.ColumnSpan="2" Classes="section" />
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="3">
                        <TextBlock x:Name="FormatLabel" Classes="muted" />
                        <ComboBox x:Name="FormatCombo" SelectionChanged="FormatCombo_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Spacing="3">
                        <TextBlock x:Name="KindLabel" Classes="muted" />
                        <ComboBox x:Name="KindCombo" SelectionChanged="KindCombo_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Spacing="3">
                        <TextBlock x:Name="StartLabel" Classes="muted" />
                        <TextBox x:Name="StartTextBox" Text="1" TextChanged="OptionsChanged" />
                    </StackPanel>
                    <StackPanel Grid.Row="3" Spacing="3">
                        <TextBlock x:Name="CountLabel" Classes="muted" />
                        <TextBox x:Name="CountTextBox" Text="0" TextChanged="OptionsChanged" />
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="1" Spacing="3">
                        <TextBlock x:Name="MaximumLengthLabel" Classes="muted" />
                        <TextBox x:Name="MaximumLengthTextBox" Text="0" TextChanged="OptionsChanged" />
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Spacing="3">
                        <TextBlock x:Name="CaseModeLabel" Classes="muted" />
                        <ComboBox x:Name="CaseModeCombo" SelectionChanged="CaseModeCombo_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Grid.Row="5" Spacing="3">
                        <TextBlock x:Name="StartPositionLabel" Classes="muted" />
                        <TextBox x:Name="StartPositionTextBox" Text="1" TextChanged="OptionsChanged" />
                    </StackPanel>
                    <CheckBox x:Name="FromEndCheckBox"
                              Grid.Row="5"
                              Grid.Column="1"
                              VerticalAlignment="Bottom"
                              Click="OptionsChanged" />
                    <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Spacing="6">
                        <CheckBox x:Name="AdaptDmtCheckBox" Click="AdaptDmtCheckBox_Click">
                            <TextBlock x:Name="AdaptDmtText" TextWrapping="Wrap" />
                        </CheckBox>
                        <Button x:Name="PreviewButton" Click="PreviewButton_Click" />
                    </StackPanel>
                    <TextBlock x:Name="FormatHelpText"
                               Grid.Row="7"
                               Grid.ColumnSpan="2"
                               Classes="muted"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Classes="panel">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                <TextBlock x:Name="PreviewTitle" Classes="section" />
                <TextBlock x:Name="SummaryText" Grid.Row="1" TextWrapping="Wrap" />
                <DataGrid x:Name="PreviewGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding DeviceName}" Width="1.1*" />
                        <DataGridTextColumn Header="TX/RX" Binding="{Binding Kind}" Width="65" />
                        <DataGridTextColumn Binding="{Binding ChannelNumber}" Width="75" />
                        <DataGridTextColumn Binding="{Binding OriginalLabel}" Width="1.3*" />
                        <DataGridTextColumn Binding="{Binding ExportedLabel}" Width="1.3*" />
                        <DataGridTextColumn Binding="{Binding Warning}" Width="1.4*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <Button x:Name="CancelButton" Grid.Column="1" MinWidth="100" Click="CancelButton_Click" />
            <Button x:Name="ExportButton" Grid.Column="2" Classes="primary" MinWidth="120" Click="ExportButton_Click" />
        </Grid>
    </Grid>
</Window>
