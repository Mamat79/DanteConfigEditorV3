<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DanteConfigEditor.Mac.PatchWorkspaceDialog"
        Title="Patch visuel"
        Width="1200"
        Height="800"
        MinWidth="960"
        MinHeight="640"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.Styles>
        <Style Selector="Button.matrixCell">
            <Setter Property="Width" Value="84" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.matrixCell.assigned">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="TextBlock.pendingRow">
            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="18" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="4">
                <TextBlock x:Name="TitleText" Text="Patch visuel" FontSize="21" FontWeight="Bold" />
                <TextBlock x:Name="IntroText"
                           Classes="muted"
                           Text="Préparez les affectations puis appliquez-les en une seule opération." />
            </StackPanel>
            <TextBlock x:Name="PendingHeaderText"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,58,*" ColumnSpacing="0">
            <StackPanel Spacing="4">
                <TextBlock x:Name="RxDeviceLabel" Classes="muted" Text="Machine réceptrice RX" />
                <ComboBox x:Name="RxDeviceCombo" SelectionChanged="RxDeviceCombo_SelectionChanged" />
            </StackPanel>
            <Button x:Name="SwapDeviceSelectionButton"
                    Grid.Column="1"
                    Width="42"
                    Height="36"
                    Margin="8,22,8,0"
                    Padding="0"
                    VerticalAlignment="Center"
                    FontSize="20"
                    Click="SwapDeviceSelectionButton_Click">⇄</Button>
            <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock x:Name="TxDeviceLabel" Classes="muted" Text="Machine émettrice TX" />
                <ComboBox x:Name="TxDeviceCombo" SelectionChanged="TxDeviceCombo_SelectionChanged" />
            </StackPanel>
        </Grid>

        <TabControl x:Name="PatchModeTabs" Grid.Row="2">
            <TabItem x:Name="AssignmentTab" Header="Glisser-déposer et série">
                <Grid ColumnDefinitions="*,270,*" RowDefinitions="Auto,*" ColumnSpacing="14" Margin="12">
                    <TextBlock x:Name="RxListHeading"
                               Text="Canaux RX et source actuelle"
                               FontWeight="SemiBold" />
                    <Border x:Name="RxDropBorder"
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5">
                        <ListBox x:Name="RxChannelList"
                                 SelectionChanged="RxChannelList_SelectionChanged"
                                 DragDrop.AllowDrop="True"
                                 DragDrop.DragOver="RxChannelList_DragOver"
                                 DragDrop.DragLeave="RxChannelList_DragLeave"
                                 DragDrop.Drop="RxChannelList_Drop">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Grid.RowSpan="2"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <TextBlock x:Name="DragHintText"
                                   Classes="muted"
                                   TextAlignment="Center"
                                   Text="Sélectionnez un ou plusieurs TX puis déposez-les sur le premier RX." />
                        <Button x:Name="AssignSequentialButton"
                                Classes="primary"
                                HorizontalAlignment="Stretch"
                                Click="AssignSequentialButton_Click">
                            Affecter à partir du RX sélectionné
                        </Button>
                        <Button x:Name="RemoveSelectedRxButton"
                                HorizontalAlignment="Stretch"
                                Click="RemoveSelectedRxButton_Click">
                            Déconnecter le RX sélectionné
                        </Button>
                        <Separator Margin="0,5" />
                        <TextBlock x:Name="OneToOneHeading"
                                   Text="Patch 1:1"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center" />
                        <Grid ColumnDefinitions="86,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                            <TextBlock x:Name="OneToOneFirstRxLabel"
                                       VerticalAlignment="Center"
                                       Text="Premier RX" />
                            <ComboBox x:Name="OneToOneFirstRxCombo"
                                      Grid.Column="1"
                                      SelectionChanged="OneToOneControl_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock x:Name="OneToOneFirstTxLabel"
                                       Grid.Row="1"
                                       VerticalAlignment="Center"
                                       Text="Premier TX" />
                            <ComboBox x:Name="OneToOneFirstTxCombo"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      SelectionChanged="OneToOneControl_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock x:Name="OneToOneCountLabel"
                                       Grid.Row="2"
                                       VerticalAlignment="Center"
                                       Text="Nombre" />
                            <TextBox x:Name="OneToOneCountTextBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     Text="1"
                                     TextChanged="OneToOneCountTextBox_TextChanged" />
                        </Grid>
                        <TextBlock x:Name="OneToOneCapacityText"
                                   Classes="muted"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                        <Button x:Name="PreviewOneToOneButton"
                                Classes="primary"
                                HorizontalAlignment="Stretch"
                                Click="PreviewOneToOneButton_Click">
                            Prévisualiser et ajouter au lot
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="TxListHeading"
                               Grid.Column="2"
                               Text="Canaux TX disponibles"
                               FontWeight="SemiBold" />
                    <ListBox x:Name="TxChannelList"
                             Grid.Column="2"
                             Grid.Row="1"
                             Margin="0,8,0,0"
                             SelectionMode="Multiple"
                             PointerPressed="TxChannelList_PointerPressed"
                             PointerMoved="TxChannelList_PointerMoved"
                             PointerReleased="TxChannelList_PointerReleased">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem x:Name="MatrixTab" Header="Grille de patch">
                <Grid RowDefinitions="Auto,*" RowSpacing="8" Margin="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBlock x:Name="MatrixHintText"
                                   Classes="muted"
                                   VerticalAlignment="Center"
                                   Text="RX en lignes, TX en colonnes. Cliquez dans une case pour affecter ou retirer un patch." />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                            <Button x:Name="MatrixZoomOutButton" Width="34" Padding="0" Click="MatrixZoomOutButton_Click">−</Button>
                            <Button x:Name="MatrixZoomResetButton" MinWidth="62" Click="MatrixZoomResetButton_Click">100 %</Button>
                            <Button x:Name="MatrixZoomInButton" Width="34" Padding="0" Click="MatrixZoomInButton_Click">+</Button>
                            <Button x:Name="MatrixZoomFitButton" Click="MatrixZoomFitButton_Click">Ajuster</Button>
                            <TextBlock x:Name="MatrixZoomText" Width="58" Text="100 %" TextAlignment="Center" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1"
                          x:Name="MatrixViewport"
                          RowDefinitions="Auto,*"
                          ColumnDefinitions="220,*"
                          PointerWheelChanged="MatrixViewport_PointerWheelChanged">
                        <Border Grid.Row="0"
                                Grid.Column="0"
                                MinHeight="54"
                                Padding="8,4"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0,1,1">
                            <TextBlock x:Name="MatrixCornerHeader"
                                       Text="Canal RX"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                        <ScrollViewer x:Name="MatrixTxHeaderScrollViewer"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      Background="{DynamicResource PanelBackgroundBrush}">
                            <Grid x:Name="MatrixTxHeaderPanel" />
                        </ScrollViewer>
                        <ScrollViewer x:Name="MatrixRxHeaderScrollViewer"
                                      Grid.Row="1"
                                      Grid.Column="0"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Hidden"
                                      Background="{DynamicResource PanelBackgroundBrush}">
                            <Grid x:Name="MatrixRxHeaderPanel" />
                        </ScrollViewer>
                        <ScrollViewer x:Name="MatrixBodyScrollViewer"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      ScrollChanged="MatrixBodyScrollViewer_ScrollChanged">
                            <Grid x:Name="MatrixPanel" />
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
            <StackPanel VerticalAlignment="Center" Spacing="3">
                <TextBlock x:Name="InfoText" Classes="muted" />
                <TextBlock x:Name="PendingFooterText" Classes="muted" />
            </StackPanel>
            <Button x:Name="ResetPendingButton"
                    Grid.Column="1"
                    Click="ResetPendingButton_Click">
                Annuler les changements visuels
            </Button>
            <Button x:Name="CancelButton"
                    Grid.Column="2"
                    Click="CancelButton_Click">
                Fermer sans appliquer
            </Button>
            <Button x:Name="ApplyButton"
                    Grid.Column="3"
                    Classes="primary"
                    Click="ApplyButton_Click">
                Appliquer au projet
            </Button>
        </Grid>
    </Grid>
</Window>
