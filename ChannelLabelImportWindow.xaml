<Window x:Class="DanteConfigEditor.ChannelLabelImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importer des labels"
        Width="1040"
        Height="720"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="210" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="12" Background="#EEF4FF" BorderBrush="#B9D1F7" BorderThickness="1" CornerRadius="5">
            <StackPanel>
                <TextBlock x:Name="IntroTextBlock"
                           Text="Choisissez la liste source, les machines Dante cibles et la plage. Aucun XML n'est modifié avant Appliquer."
                           TextWrapping="Wrap" />
                <TextBlock x:Name="SourceInfoTextBlock" Margin="0,5,0,0" Foreground="#475569" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <GroupBox x:Name="SourceGroupBox" Header="Source" Margin="0,0,10,0" Padding="10">
                <StackPanel>
                    <Label x:Name="SourceSetLabel" Content="Liste de labels" />
                    <ComboBox x:Name="SourceSetComboBox" SelectionChanged="SourceSetComboBox_SelectionChanged" />
                    <CheckBox x:Name="AutoMatchCheckBox"
                              Content="Associer automatiquement les listes aux machines de même nom"
                              Margin="0,12,0,0"
                              Checked="AutoMatchCheckBox_Changed"
                              Unchecked="AutoMatchCheckBox_Changed" />
                </StackPanel>
            </GroupBox>

            <GroupBox x:Name="TargetsGroupBox" Grid.Column="1" Header="Machines Dante cibles" Margin="0,0,10,0" Padding="8">
                <DataGrid x:Name="TargetDevicesGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Extended">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn x:Name="UseTargetColumn" Header="Utiliser" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="75" />
                        <DataGridTextColumn x:Name="TargetNameColumn" Header="Machine" Binding="{Binding Name}" IsReadOnly="True" Width="*" />
                        <DataGridTextColumn x:Name="TargetCountsColumn" Header="TX / RX" Binding="{Binding Counts}" IsReadOnly="True" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox x:Name="MappingGroupBox" Grid.Column="2" Header="Correspondance" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.ColumnSpan="2">
                        <Label x:Name="TargetKindLabel" Content="Type de canal Dante" />
                        <ComboBox x:Name="TargetKindComboBox">
                            <ComboBoxItem Content="TX" Tag="tx" />
                            <ComboBoxItem Content="RX" Tag="rx" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,6,6,0">
                        <Label x:Name="SourceStartLabel" Content="Premier canal source" />
                        <TextBox x:Name="SourceStartTextBox" Text="1" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="6,6,0,0">
                        <Label x:Name="TargetStartLabel" Content="Premier canal Dante" />
                        <TextBox x:Name="TargetStartTextBox" Text="1" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,6,0,0">
                        <Label x:Name="CountLabel" Content="Nombre de canaux" />
                        <TextBox x:Name="CountTextBox" Text="1" />
                    </StackPanel>
                    <Button x:Name="PreviewButton"
                            Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Margin="0,12,0,0"
                            Padding="10,7"
                            Content="Prévisualiser"
                            Click="PreviewButton_Click" />
                </Grid>
            </GroupBox>
        </Grid>

        <GroupBox x:Name="PreviewGroupBox" Grid.Row="2" Header="Prévisualisation" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="PreviewSummaryTextBlock"
                           Text="Prévisualisez le transfert pour vérifier chaque correspondance."
                           Margin="0,0,0,8"
                           TextWrapping="Wrap" />
                <DataGrid x:Name="PreviewGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="PreviewSourceDeviceColumn" Header="Source" Binding="{Binding SourceDevice}" Width="1.15*" />
                        <DataGridTextColumn x:Name="PreviewSourceChannelColumn" Header="Canal source" Binding="{Binding SourceChannel}" Width="90" />
                        <DataGridTextColumn x:Name="PreviewTargetDeviceColumn" Header="Machine Dante" Binding="{Binding TargetDevice}" Width="1.15*" />
                        <DataGridTextColumn x:Name="PreviewTargetChannelColumn" Header="Canal Dante" Binding="{Binding TargetDanteId}" Width="90" />
                        <DataGridTextColumn x:Name="PreviewBeforeColumn" Header="Avant" Binding="{Binding CurrentLabel}" Width="1.2*" />
                        <DataGridTextColumn x:Name="PreviewAfterColumn" Header="Après" Binding="{Binding NewLabel}" Width="1.2*" />
                        <DataGridTextColumn x:Name="PreviewStatusColumn" Header="État" Binding="{Binding StatusDisplay}" Width="110" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <DockPanel Grid.Row="3" Margin="0,14,0,0">
            <TextBlock x:Name="SafetyTextBlock"
                       Text="Les renommages TX mettront à jour les subscriptions reconnues."
                       VerticalAlignment="Center"
                       Foreground="#475569" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Annuler" MinWidth="100" Margin="0,0,8,0" IsCancel="True" />
                <Button x:Name="ApplyButton" Content="Appliquer" MinWidth="120" IsDefault="True" IsEnabled="False" Click="ApplyButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
