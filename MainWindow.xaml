<Window x:Class="DanteConfigEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dante Config Editor V3.3"
        Width="1280"
        Height="820"
        MinWidth="1120"
        MinHeight="720"
        WindowState="Maximized"
        SizeChanged="Window_SizeChanged"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#10141F" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#171D2B" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#202838" />
        <SolidColorBrush x:Key="TextBrush" Color="#F6F8FB" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#AAB4C5" />
        <SolidColorBrush x:Key="BorderLineBrush" Color="#334057" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2F80ED" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#1D5FB8" />
        <SolidColorBrush x:Key="DangerBrush" Color="#D64545" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#2E9D62" />

        <!-- Styles globaux de l'application. Les couleurs changent via SetTheme dans MainWindow.xaml.cs. -->
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="Padding" Value="0,8,0,4" />
        </Style>

        <DataTemplate x:Key="WhiteListTextTemplate">
            <TextBlock Text="{Binding}"
                       Foreground="#111827"
                       TextWrapping="NoWrap" />
        </DataTemplate>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Commande d'entraînement dessinée en XAML, sans image externe. -->
        <Style x:Key="AtomicButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="MinWidth" Value="176" />
            <Setter Property="MinHeight" Value="126" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid x:Name="AtomicAssembly"
                              MinWidth="170"
                              MinHeight="120"
                              ClipToBounds="True"
                              RenderTransformOrigin="0.5,0.5">
                            <Ellipse Width="112"
                                     Height="112"
                                     Fill="#C8CDD3"
                                     Stroke="#4B4F55"
                                     StrokeThickness="4">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="8"
                                                      Direction="270"
                                                      Opacity="0.75"
                                                      ShadowDepth="4"
                                                      Color="#000000" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <Ellipse x:Name="AtomicFace"
                                     Width="92"
                                     Height="92"
                                     Stroke="#7F0B0B"
                                     StrokeThickness="3">
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.35,0.25"
                                                         GradientOrigin="0.32,0.2"
                                                         RadiusX="0.78"
                                                         RadiusY="0.78">
                                        <GradientStop Color="#FF6B5E" Offset="0" />
                                        <GradientStop Color="#F32121" Offset="0.45" />
                                        <GradientStop Color="#A60000" Offset="1" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False">
                                <TextBlock Text="ATOMIC"
                                           Foreground="#FFF4F4"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center" />
                                <TextBlock Text="BOMB"
                                           Foreground="White"
                                           FontSize="19"
                                           FontWeight="Black"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AtomicFace" Property="Stroke" Value="#FFD0D0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="AtomicAssembly" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="3" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="AtomicAssembly" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
        </Style>

        <!-- Les listes restent volontairement en noir sur fond blanc, même en thème sombre. -->
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="ItemTemplate" Value="{StaticResource WhiteListTextTemplate}" />
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#E5E7EB" />
                    <Setter Property="Foreground" Value="#111827" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E5E7EB" />
                    <Setter Property="Foreground" Value="#111827" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemTemplate" Value="{StaticResource WhiteListTextTemplate}" />
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6" />
                    <Setter Property="Foreground" Value="#111827" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E5E7EB" />
                    <Setter Property="Foreground" Value="#111827" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PanelListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="PanelListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,8,0,8" />
        </Style>

        <Style TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,6,12,6" />
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TabPanel x:Name="HeaderPanel"
                                      Panel.ZIndex="1"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Margin="0,0,0,-1" />
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,3,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="10" />
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AutoGenerateColumns" Value="False" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Barre haute : actions de fichier, état du document et changement de thème. -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderLineBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Le titre et l'état restent sur une ligne bornée. Le chemin est
                     tronqué plutôt que replié, afin de ne jamais agrandir la barre. -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,18,0" VerticalAlignment="Center">
                        <TextBlock Text="Dante Config Editor V3.3"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   TextWrapping="NoWrap" />
                        <TextBlock x:Name="FilePathTextBlock"
                                   Text="Aucun fichier ouvert"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="12"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="DirtyStateTextBlock"
                                   Text="Non modifié"
                                   TextWrapping="NoWrap"
                                   Margin="0,0,14,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                        <TextBlock x:Name="LanguageLabelTextBlock"
                                   Text="Langue"
                                   TextWrapping="NoWrap"
                                   Margin="0,0,8,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                        <ComboBox x:Name="LanguageComboBox"
                                  Width="105"
                                  Margin="0,0,8,8"
                                  AutomationProperties.Name="Langue de l'interface"
                                  SelectionChanged="LanguageComboBox_SelectionChanged" />
                        <ToggleButton x:Name="ThemeToggleButton"
                                      Content="Thème clair"
                                      AutomationProperties.Name="Changer le thème"
                                      Checked="ThemeToggleButton_Checked"
                                      Unchecked="ThemeToggleButton_Unchecked" />
                    </StackPanel>
                </Grid>

                <!-- Les commandes passent sur une seconde ligne si la fenêtre est
                     étroite, sans masquer les onglets ni le tableau des machines. -->
                <WrapPanel Grid.Row="1" Margin="0,10,0,0" VerticalAlignment="Center">
                    <Button Content="Ouvrir XML" Click="OpenButton_Click" ToolTip="Charge un export XML Dante Controller." />
                    <Button x:Name="MergeXmlButton" Content="Ajouter XML au projet" Style="{StaticResource SecondaryButtonStyle}" Click="MergeXmlButton_Click" ToolTip="Ajoute les machines d'un autre XML au projet ouvert. Les doublons peuvent être renommés." />
                    <Button x:Name="SaveAsButton" Content="Enregistrer sous" Click="SaveAsButton_Click" ToolTip="Enregistre un nouveau XML et crée un backup de sécurité." />
                    <Button x:Name="ActivateEditButton" Content="Activer l'édition" Style="{StaticResource SecondaryButtonStyle}" Click="ActivateEditButton_Click" ToolTip="Autorise les modifications dans l'interface. La sauvegarde reste faite sous un nouveau nom." />
                    <Button x:Name="UndoLastButton" Content="Annuler action" Style="{StaticResource SecondaryButtonStyle}" Click="UndoLastButton_Click" IsEnabled="False" ToolTip="Annule la dernière action réalisée dans cette session." />
                    <Button x:Name="RevertButton" Content="Annuler les changements" Style="{StaticResource SecondaryButtonStyle}" Click="RevertButton_Click" ToolTip="Recharge le fichier XML d'origine et abandonne les modifications non sauvegardées." />
                    <ComboBox x:Name="RecentFilesComboBox"
                              Width="230"
                              Margin="0,0,8,8"
                              AutomationProperties.Name="Fichiers XML récents"
                              ToolTip="Liste les derniers XML ouverts." />
                    <Button Content="Ouvrir récent" Style="{StaticResource SecondaryButtonStyle}" Click="OpenRecentButton_Click" ToolTip="Ouvre le fichier sélectionné dans la liste récente." />
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Corps principal : navigation à gauche, onglets de travail à droite. -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderLineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Projet" FontWeight="SemiBold" FontSize="15" />
                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderLineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,10,0,0">
                        <TextBlock x:Name="ProjectSummaryTextBlock"
                                   Text="Chargez un fichier XML pour commencer."
                                    Foreground="{DynamicResource MutedTextBrush}" />
                        </Border>

                        <!-- Les alertes restent dans le rail de navigation afin de ne pas réduire
                             la hauteur disponible pour les réglages et le tableau des machines. -->
                        <Border x:Name="ImportantWarningsBorder"
                                Background="#FEF2F2"
                                BorderBrush="{DynamicResource DangerBrush}"
                                BorderThickness="2"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,12,0,0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="POINTS À VÉRIFIER"
                                           Foreground="#991B1B"
                                           FontWeight="Bold"
                                           FontSize="13"
                                           Margin="0,0,0,6" />
                                <ScrollViewer MaxHeight="115"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock x:Name="ImportantWarningsTextBlock"
                                               Foreground="#991B1B"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                </ScrollViewer>
                                <Button Content="Voir les machines"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Foreground="#991B1B"
                                        Background="#FEE2E2"
                                        BorderBrush="#FCA5A5"
                                        Padding="10,5"
                                        Margin="0,8,0,0"
                                        Click="ImportantWarningsDetailsButton_Click" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Recherche"
                                   FontWeight="SemiBold"
                                   Margin="0,18,0,6" />
                        <TextBox x:Name="GlobalSearchTextBox"
                                 TextChanged="GlobalSearchTextBox_TextChanged" />
                        <Grid Height="135" Margin="0,8,0,0">
                            <ListBox x:Name="GlobalSearchListBox"
                                     Style="{StaticResource PanelListBoxStyle}"
                                     ItemContainerStyle="{StaticResource PanelListBoxItemStyle}"
                                     SelectionChanged="GlobalSearchListBox_SelectionChanged" />
                            <TextBlock x:Name="GlobalSearchHintTextBlock"
                                       Text="Tapez au moins 2 caractères pour chercher"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="10"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       IsHitTestVisible="False" />
                        </Grid>
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom"
                            Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderLineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10">
                        <TextBlock Text="Mode hors ligne : l'application modifie uniquement les fichiers XML chargés. Elle ne se connecte pas au réseau Dante." 
                                   Foreground="{DynamicResource MutedTextBrush}" />
                    </Border>
                </DockPanel>
            </Border>

            <TabControl x:Name="MainTabs"
                        Grid.Column="1"
                        Margin="12"
                        Background="Transparent"
                        BorderThickness="0"
                        SelectionChanged="MainTabs_SelectionChanged">
                <TabItem Header="Configuration">
                    <Grid Margin="0,6,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid x:Name="ConfigurationEditorsGrid" Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>

                                <GroupBox Header="Machine sélectionnée" Margin="0,0,12,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.ColumnSpan="2">
                                            <Label Content="Machine" />
                                            <ComboBox x:Name="DeviceComboBox" SelectionChanged="DeviceComboBox_SelectionChanged" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Margin="0,8,8,0">
                                            <Label Content="Nouveau nom" />
                                            <TextBox x:Name="NewNameTextBox" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,8,0,0">
                                            <Label Content="Mode réseau" />
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="RedundantRadioButton" Content="Redondant" GroupName="NetworkMode" />
                                                <RadioButton x:Name="DaisychainRadioButton" Content="Daisychain" GroupName="NetworkMode" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Margin="0,8,8,0">
                                            <Label Content="Latence unicast" />
                                            <ComboBox x:Name="LatencyComboBox" ToolTip="La valeur affichée est en ms. Le XML conserve la valeur brute Dante." />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,8,0,0">
                                            <Label Content="Horloge" />
                                            <CheckBox x:Name="PreferredMasterCheckBox" Content="Preferred master" />
                                        </StackPanel>

                                        <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="ApplyDeviceSettingsButton"
                                                    Content="Appliquer les paramètres"
                                                    HorizontalAlignment="Stretch"
                                                    Click="ApplyDeviceSettingsButton_Click"
                                                    ToolTip="Applique en une seule fois le nom, le mode réseau, la latence et le statut Preferred master." />
                                            <Button x:Name="OpenDeviceDetailsButton"
                                                    Grid.Column="1"
                                                    Content="Détail machine"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    ToolTip="Ouvre tous les réglages de la machine : IP automatique ou fixe, formats audio et noms des canaux."
                                                    Click="OpenDeviceDetailsButton_Click" />
                                        </Grid>

                                        <UniformGrid Grid.Row="4" Grid.ColumnSpan="2" Columns="4" Margin="0,2,0,0">
                                            <Button x:Name="ResetDevicePatchesButton"
                                                    Content="Reset patch RX/TX"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    ToolTip="Déconnecte les RX de la machine et supprime les patchs qui utilisent ses TX."
                                                    Click="ResetDevicePatchesButton_Click" />
                                            <Button x:Name="ResetDeviceRxPatchesButton"
                                                    Content="Reset patch RX"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    ToolTip="Déconnecte seulement les entrées RX de la machine sélectionnée."
                                                    Click="ResetDeviceRxPatchesButton_Click" />
                                            <Button x:Name="ResetDeviceTxPatchesButton"
                                                    Content="Reset patch TX"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    ToolTip="Supprime seulement les patchs qui utilisent les TX de la machine sélectionnée."
                                                    Click="ResetDeviceTxPatchesButton_Click" />
                                            <Button x:Name="DeleteDeviceButton"
                                                    Content="Supprimer"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    ToolTip="Supprime la machine et nettoie les patchs qui lui sont associés."
                                                    Click="DeleteDeviceButton_Click" />
                                        </UniformGrid>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Grid.Column="1" Header="Canaux de la machine" Margin="0,0,12,0">
                                    <StackPanel>
                                        <Label Content="Canal à renommer" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="ChannelKindComboBox"
                                                      SelectionChanged="ChannelSelector_Changed"
                                                      Margin="0,0,8,0" />
                                            <ComboBox x:Name="ChannelComboBox"
                                                      Grid.Column="1"
                                                      SelectionChanged="ChannelComboBox_SelectionChanged" />
                                        </Grid>

                                        <Label Content="Nouveau nom de canal" />
                                        <TextBox x:Name="NewChannelNameTextBox" />
                                        <WrapPanel>
                                            <Button x:Name="RenameChannelButton" Content="Renommer le canal" Click="RenameChannelButton_Click" />
                                            <Button x:Name="ResetDeviceChannelsButton" Content="Réinitialiser les canaux de la machine" Style="{StaticResource SecondaryButtonStyle}" Click="ResetDeviceChannelsButton_Click" />
                                        </WrapPanel>
                                        <Separator Margin="0,6,0,6" />
                                        <TextBlock Text="Renommage en série" FontWeight="SemiBold" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,8,0">
                                                <Label Content="Canal début" />
                                                <ComboBox x:Name="BatchRenameStartChannelComboBox" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <Label Content="Canal fin" />
                                                <ComboBox x:Name="BatchRenameEndChannelComboBox" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="90" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,8,0">
                                                <Label Content="Préfixe" />
                                                <TextBox x:Name="BatchRenamePrefixTextBox"
                                                         ToolTip="Préfixe simple : HF donnera HF 01, HF 02. Modèle avancé : HF {00}, IN-{device}-{000}, ou {n} sans zéro." />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <Label Content="Numéro" />
                                                <TextBox x:Name="BatchRenameStartTextBox" Text="1" />
                                            </StackPanel>
                                        </Grid>
                                        <Button x:Name="BatchRenameButton" Content="Renommer la série" Style="{StaticResource SecondaryButtonStyle}" Click="BatchRenameButton_Click" />
                                    </StackPanel>
                                </GroupBox>

                                <StackPanel Grid.Column="2">
                                    <GroupBox Header="Listes rapides">
                                        <WrapPanel>
                                            <Button Content="Redondants" Style="{StaticResource SecondaryButtonStyle}" Click="ListRedundantButton_Click" />
                                            <Button Content="Daisychain" Style="{StaticResource SecondaryButtonStyle}" Click="ListDaisychainButton_Click" />
                                            <Button Content="Latences" Style="{StaticResource SecondaryButtonStyle}" Click="ListLatenciesButton_Click" />
                                            <Button Content="Sample rates" Style="{StaticResource SecondaryButtonStyle}" Click="ListSampleRatesButton_Click" />
                                            <Button Content="Bits" Style="{StaticResource SecondaryButtonStyle}" Click="ListEncodingsButton_Click" />
                                            <Button Content="IP fixes" Style="{StaticResource SecondaryButtonStyle}" Click="ListStaticIpsButton_Click" />
                                            <Button Content="Preferred masters" Style="{StaticResource SecondaryButtonStyle}" Click="ListPreferredMastersButton_Click" />
                                        </WrapPanel>
                                    </GroupBox>

                                    <GroupBox Header="Actions globales">
                                        <TabControl Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderLineBrush}"
                                                    Foreground="{DynamicResource TextBrush}">
                                            <TabItem Header="Réseau / audio">
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Margin="0,0,8,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <RadioButton x:Name="GlobalRedundantRadioButton" Content="Redondant" GroupName="GlobalNetworkMode" />
                                                            <RadioButton x:Name="GlobalDaisychainRadioButton" Content="Daisychain" GroupName="GlobalNetworkMode" />
                                                        </StackPanel>
                                                        <Button x:Name="ApplyAllNetworkButton" Content="Appliquer le mode à tous" Click="ApplyAllNetworkButton_Click" ToolTip="Applique le mode réseau à la cible choisie, en ignorant les machines verrouillées." />

                                                        <Label Content="Latence globale" />
                                                        <ComboBox x:Name="GlobalLatencyComboBox" ToolTip="La valeur affichée est en ms. Le XML conserve la valeur brute Dante." />
                                                        <Button x:Name="ApplyAllLatencyButton" Content="Appliquer la latence à tous" Click="ApplyAllLatencyButton_Click" ToolTip="Applique la latence à la cible choisie après prévisualisation." />
                                                        <Button x:Name="ResetAllChannelsButton" Content="Réinitialiser tous les canaux" Style="{StaticResource SecondaryButtonStyle}" Click="ResetAllChannelsButton_Click" ToolTip="Réinitialise les noms de canaux TX/RX de la cible choisie, en respectant les verrous." />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1">
                                                        <Label Content="Sample rate globale" />
                                                        <ComboBox x:Name="GlobalSampleRateComboBox" IsEditable="True" />
                                                        <Button x:Name="ApplyAllSampleRateButton" Content="Appliquer la fréquence à tous" Click="ApplyAllSampleRateButton_Click" ToolTip="Applique la sample rate à la cible choisie. À vérifier avant import Dante." />

                                                        <Label Content="Bits par échantillon globaux" />
                                                        <ComboBox x:Name="GlobalEncodingComboBox" IsEditable="True" />
                                                        <Button x:Name="ApplyAllEncodingButton" Content="Appliquer les bits à tous" Click="ApplyAllEncodingButton_Click" ToolTip="Applique les bits par échantillon à la cible choisie." />
                                                    </StackPanel>
                                                </Grid>
                                            </TabItem>

                                            <TabItem Header="IP">
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Margin="0,0,8,0">
                                                        <Label Content="Préfixe IP" />
                                                        <TextBox x:Name="GlobalIpPrefixTextBox" Text="192.168.1" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1">
                                                        <Label Content="Premier numéro" />
                                                        <TextBox x:Name="GlobalIpStartTextBox" Text="10" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="1" Margin="0,8,8,0">
                                                        <Label Content="Masque" />
                                                        <TextBox x:Name="GlobalIpNetmaskTextBox" Text="255.255.255.0" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
                                                        <Label Content="Passerelle" />
                                                        <TextBox x:Name="GlobalIpGatewayTextBox" Text="0.0.0.0" />
                                                    </StackPanel>

                                                    <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                                        <Button x:Name="ApplyAllIpStaticButton" Content="Fixer les IP en série" Click="ApplyAllIpStaticButton_Click" ToolTip="Attribue des IP fixes en série aux machines de la cible qui ont une interface IPv4 modifiable." />
                                                        <Button x:Name="ApplyAllIpAutoButton" Content="Mettre toutes les IP en automatique" Style="{StaticResource SecondaryButtonStyle}" Click="ApplyAllIpAutoButton_Click" ToolTip="Repasse les IP reconnues en automatique pour la cible choisie." />
                                                    </WrapPanel>
                                                </Grid>
                                            </TabItem>

                                            <TabItem Header="Profils">
                                                <StackPanel Margin="0,8,0,0">
                                                    <Label Content="Profil rapide" />
                                                    <ComboBox x:Name="QuickProfileComboBox" />
                                                    <Button x:Name="ApplyQuickProfileButton"
                                                            Content="Appliquer le profil à la cible"
                                                            Margin="0,10,0,0"
                                                            Click="ApplyQuickProfileButton_Click"
                                                            ToolTip="Applique en une seule action les formats audio, la latence, l'IP automatique et éventuellement le mode réseau du profil à la cible choisie." />
                                                </StackPanel>
                                            </TabItem>
                                        </TabControl>
                                    </GroupBox>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,0,0,10">
                                <DockPanel LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button x:Name="ShowDeviceChangesButton"
                                                Content="Avant / après"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="ShowDeviceChangesButton_Click"
                                                ToolTip="Affiche toutes les différences de machines, canaux et patchs depuis l'ouverture du XML." />
                                        <Button x:Name="ToggleConfigurationEditorsButton"
                                                Content="Réduire les réglages"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="ToggleConfigurationEditorsButton_Click"
                                                ToolTip="Masque les panneaux de réglage pour agrandir le tableau des machines." />
                                    </StackPanel>
                                    <WrapPanel VerticalAlignment="Center">
                                        <Label Content="Filtre machines"
                                               ToolTip="Filtre seulement le tableau des machines, sans modifier le XML." />
                                        <ComboBox x:Name="DeviceFilterComboBox"
                                                  Width="190"
                                                  Margin="0,0,12,8"
                                                  SelectionChanged="DeviceFilter_SelectionChanged"
                                                  ToolTip="Affiche rapidement les machines en IP fixe, preferred master, redondantes, daisychain, sans TX/RX ou avec formats différents." />
                                        <Label Content="Cible actions"
                                               ToolTip="Détermine quelles machines seront touchées par les actions globales." />
                                        <ComboBox x:Name="TargetScopeComboBox"
                                                  Width="230"
                                                  Margin="0,0,12,8"
                                                  ToolTip="Choisissez si les actions globales s'appliquent à toutes les machines non verrouillées, à la sélection ou au filtre affiché." />
                                        <Button Content="Sélectionner visibles"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="SelectVisibleDevicesButton_Click"
                                                ToolTip="Sélectionne toutes les machines actuellement visibles dans le tableau." />
                                        <Button Content="Effacer sélection"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="ClearDeviceSelectionButton_Click"
                                                ToolTip="Vide la sélection multiple du tableau." />
                                        <Button Content="Verrouiller sélection"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="LockSelectedDevicesButton_Click"
                                                ToolTip="Les machines verrouillées sont ignorées par les actions globales." />
                                        <Button Content="Déverrouiller sélection"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="UnlockSelectedDevicesButton_Click"
                                                ToolTip="Retire le verrou des machines sélectionnées." />
                                    </WrapPanel>
                                </DockPanel>
                            </Border>

                            <DataGrid x:Name="DeviceGrid"
                                      Grid.Row="2"
                                      MinHeight="160"
                                      SelectionMode="Extended"
                                      SelectionUnit="FullRow"
                                      MouseDoubleClick="DeviceGrid_MouseDoubleClick">
                                <DataGrid.RowStyle>
                                    <Style TargetType="{x:Type DataGridRow}">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                <Setter Property="Background" Value="#3B2F12" />
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentDarkBrush}" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Lock" Width="0.55*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsLocked, Mode=OneWay}"
                                                          HorizontalAlignment="Center"
                                                          Click="DeviceLockCheckBox_Click"
                                                          ToolTip="Verrouille cette machine pour que les actions globales ne la modifient pas." />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Device" Binding="{Binding Name}" Width="2*" />
                                    <DataGridTextColumn Header="Friendly name" Binding="{Binding FriendlyName}" Width="2*" />
                                    <DataGridTextColumn Header="Réseau" Binding="{Binding NetworkMode}" Width="*" />
                                    <DataGridTextColumn Header="Latence" Binding="{Binding LatencyDisplay}" Width="*" />
                                    <DataGridTextColumn Header="Sample rate" Binding="{Binding SampleRateDisplay}" Width="*" />
                                    <DataGridTextColumn Header="Bits" Binding="{Binding EncodingDisplay}" Width="0.7*" />
                                    <DataGridTextColumn Header="IP" Binding="{Binding IpModeDisplay}" Width="1.2*" />
                                    <DataGridTemplateColumn Header="Preferred" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding PreferredMaster, Mode=OneWay}"
                                                          HorizontalAlignment="Center"
                                                          Click="DevicePreferredMasterCheckBox_Click" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="TX" Binding="{Binding TxCount}" Width="0.7*" />
                                    <DataGridTextColumn Header="RX" Binding="{Binding RxCount}" Width="0.7*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem x:Name="ClassicPatchTab" Header="Patch">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="245" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.RowSpan="3"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderLineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,14,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Filtre émetteur TX" FontWeight="SemiBold" />
                                <ListBox x:Name="SenderDeviceList"
                                         Grid.Row="1"
                                         SelectionChanged="SenderDeviceList_SelectionChanged"
                                         Margin="0,8,0,16" />

                                <TextBlock Grid.Row="2" Text="Filtre récepteur RX" FontWeight="SemiBold" />
                                <ListBox x:Name="ReceiverDeviceList"
                                         Grid.Row="3"
                                         SelectionChanged="ReceiverDeviceList_SelectionChanged"
                                         Margin="0,8,0,0" />
                                <Button x:Name="OpenVisualPatchButton"
                                        Grid.Row="4"
                                        Content="Easy patch"
                                        Margin="0,12,0,0"
                                        Click="OpenVisualPatchButton_Click"
                                        ToolTip="Ouvre l'onglet Easy patch." />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderLineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Label Content="Recherche device ou canal" />
                                <Label Grid.Column="1" Content="Filtre état" />
                                <Label Grid.Column="2" Content="Source TX à appliquer" />
                                <Label Grid.Column="3" Content="Canal TX à appliquer" />
                                <Label Grid.Column="4" Content="Affichage" />

                                <TextBox x:Name="PatchSearchTextBox"
                                         Grid.Row="1"
                                         TextChanged="PatchFilter_Changed"
                                         Margin="0,0,8,0" />
                                <ComboBox x:Name="PatchStateFilterComboBox"
                                          Grid.Row="1"
                                          Grid.Column="1"
                                          SelectionChanged="PatchFilter_SelectionChanged"
                                          Margin="0,0,8,0" />
                                <ComboBox x:Name="SourceDeviceComboBox"
                                          Grid.Row="1"
                                          Grid.Column="2"
                                          SelectionChanged="SourceDeviceComboBox_SelectionChanged"
                                          Margin="0,0,8,0" />
                                <ComboBox x:Name="SourceChannelComboBox"
                                          Grid.Row="1"
                                          Grid.Column="3"
                                          SelectionChanged="SourceChannelComboBox_SelectionChanged"
                                          Margin="0,0,8,0" />
                                <ComboBox x:Name="PatchViewModeComboBox"
                                          Grid.Row="1"
                                          Grid.Column="4"
                                          Width="125"
                                          SelectionChanged="PatchViewModeComboBox_SelectionChanged"
                                          Margin="0,0,8,0" />
                                <StackPanel Grid.Row="1" Grid.Column="5" Orientation="Horizontal">
                                    <Button x:Name="ApplyPatchButton" Content="Appliquer" Click="ApplyPatchButton_Click" />
                                    <Button x:Name="RemovePatchButton" Content="Supprimer" Style="{StaticResource SecondaryButtonStyle}" Click="RemovePatchButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid x:Name="PatchGrid"
                                  Grid.Column="1"
                                  Grid.Row="1"
                                  SelectionChanged="PatchGrid_SelectionChanged">
                            <DataGrid.RowStyle>
                                <Style TargetType="{x:Type DataGridRow}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RowState}" Value="Conflict">
                                            <Setter Property="Background" Value="#7F1D1D" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RowState}" Value="Modified">
                                            <Setter Property="Background" Value="#3B2F12" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RowState}" Value="Warning">
                                            <Setter Property="Background" Value="#78350F" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RowState}" Value="Local">
                                            <Setter Property="Background" Value="#064E3B" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="PatchRxDeviceColumn" Header="RX device" Binding="{Binding RxDevice}" Width="1.4*" />
                                <DataGridTextColumn x:Name="PatchRxDanteIdColumn" Header="RX Dante Id" Binding="{Binding RxDanteId}" Width="0.7*" />
                                <DataGridTextColumn x:Name="PatchRxChannelColumn" Header="RX canal" Binding="{Binding RxChannelName}" Width="1*" />
                                <DataGridTextColumn x:Name="PatchSourceFullColumn" Header="Source complète" Binding="{Binding SourceFull}" Width="1.7*" />
                                <DataGridTextColumn x:Name="PatchDisplayTxColumn" Header="TX affiché" Binding="{Binding DisplayTxDeviceName}" Width="1.2*" />
                                <DataGridTextColumn x:Name="PatchRawTxColumn" Header="TX brut XML" Binding="{Binding RawTxDeviceName}" Width="0.9*" />
                                <DataGridTextColumn x:Name="PatchResolvedTxColumn" Header="TX résolu" Binding="{Binding ResolvedTxDeviceName}" Width="1.1*" />
                                <DataGridTextColumn x:Name="PatchTxChannelColumn" Header="TX canal" Binding="{Binding TxChannelName}" Width="1*" />
                                <DataGridTextColumn x:Name="PatchTypeColumn" Header="Type" Binding="{Binding TypeLabel}" Width="1*" />
                                <DataGridCheckBoxColumn x:Name="PatchActiveColumn" Header="Actif" Binding="{Binding IsActive, Mode=OneWay}" Width="0.7*" />
                                <DataGridCheckBoxColumn x:Name="PatchModifiedColumn" Header="Modifié" Binding="{Binding IsModified, Mode=OneWay}" Width="0.8*" />
                                <DataGridTextColumn x:Name="PatchStatusColumn" Header="État" Binding="{Binding Status}" Width="1.5*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Column="1" Grid.Row="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="ConflictsOnlyCheckBox"
                                      Content="Afficher seulement les conflits"
                                      Checked="PatchFilter_Changed"
                                      Unchecked="PatchFilter_Changed"
                                      Margin="0,0,18,0"
                                      VerticalAlignment="Center" />
                            <GroupBox Grid.Column="1" Header="Renommer le RX sélectionné" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PatchRxRenameChannelTextBox"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center" />
                                    <Button x:Name="RenamePatchRxChannelButton" Grid.Column="1" Content="Renommer RX" Style="{StaticResource SecondaryButtonStyle}" Click="RenamePatchRxChannelButton_Click" />
                                </Grid>
                            </GroupBox>
                            <GroupBox Grid.Column="2" Header="Renommer le TX source" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PatchTxRenameChannelTextBox"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center" />
                                    <Button x:Name="RenamePatchTxChannelButton" Grid.Column="1" Content="Renommer TX" Style="{StaticResource SecondaryButtonStyle}" Click="RenamePatchTxChannelButton_Click" />
                                </Grid>
                            </GroupBox>
                            <TextBlock x:Name="PatchSummaryTextBlock"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem x:Name="EasyPatchTab"
                         Header="Easy patch">
                    <ContentControl x:Name="EasyPatchHost" Margin="0,8,0,0">
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderLineBrush}"
                                BorderThickness="1"
                                Padding="20">
                            <TextBlock Text="Chargez un XML pour utiliser Easy patch."
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Border>
                    </ContentControl>
                </TabItem>

                <TabItem x:Name="ExportsTab" Header="Import / Export">
                    <TabControl Margin="0,8,0,0">
                        <TabItem x:Name="ChannelLabelsTab" Header="Labels">
                            <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderLineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Import et export de labels"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Labels JSON/CSV, DMT XLSX/ODS, A&amp;H dLive/Avantis et Yamaha CL/QL."
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource MutedTextBrush}" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1"
                              MaxWidth="1100"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <GroupBox Header="Importer des labels" Margin="0,0,10,0" Padding="22">
                                <StackPanel>
                                    <TextBlock Text="Importez des labels JSON/CSV, DMT XLSX/ODS, A&amp;H CSV ou Yamaha CL/QL ZIP/CSV."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               Margin="0,0,0,18" />
                                    <Button x:Name="ImportChannelLabelsButton"
                                            Content="Importer des labels"
                                            HorizontalAlignment="Stretch"
                                            Click="ImportChannelLabelsButton_Click"
                                            ToolTip="Détecte les formats génériques, DMT, A&amp;H et Yamaha, puis prévisualise les labels avant de les appliquer aux machines Dante." />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Grid.Column="1" Header="Exporter des labels" Margin="10,0,0,0" Padding="22">
                                <StackPanel>
                                    <TextBlock Text="Exportez en générique ou créez une copie d'un modèle DMT, A&amp;H ou Yamaha."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               Margin="0,0,0,18" />
                                    <Button x:Name="ExportChannelLabelsButton"
                                            Content="Exporter des labels"
                                            HorizontalAlignment="Stretch"
                                            Click="ExportChannelLabelsButton_Click"
                                            ToolTip="Exporte les labels TX/RX et ne modifie jamais les modèles DMT, A&amp;H ou Yamaha originaux." />
                                </StackPanel>
                            </GroupBox>
                        </Grid>

                        <Button x:Name="OpenDmtProjectButton"
                                Grid.Row="2"
                                Content="Compatibilité DMT dLive / Avantis - ouvrir le projet"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Center"
                                Margin="0,18,0,6"
                                Click="OpenDmtProjectButton_Click"
                                ToolTip="Ouvre la page GitHub de dLive MIDI Tools par togrupe, dont les modèles dLive et Avantis sont compatibles." />
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="ReportsExportTab" Header="Rapports et patchbook">
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <GroupBox Header="Rapports du projet" Padding="18" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Exportez un résumé lisible de la configuration chargée."
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,16" />
                                        <Button Content="Exporter TXT"
                                                Click="ExportTxtButton_Click"
                                                HorizontalAlignment="Stretch" />
                                        <Button Content="Exporter PDF"
                                                Click="ExportPdfButton_Click"
                                                HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Grid.Column="1" Header="Patchbook" Padding="18" Margin="8,0">
                                    <StackPanel>
                                        <TextBlock Text="Choisissez le périmètre, puis exportez les affectations de patch."
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,16" />
                                        <ComboBox x:Name="PatchbookScopeComboBox"
                                                  HorizontalAlignment="Stretch"
                                                  Margin="0,0,0,8" />
                                        <Button Content="Patchbook TXT"
                                                Click="ExportPatchbookTxtButton_Click"
                                                HorizontalAlignment="Stretch" />
                                        <Button Content="Patchbook CSV"
                                                Click="ExportPatchbookCsvButton_Click"
                                                HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Grid.Column="2" Header="Analyse simple" Padding="18" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Créez une vue textuelle compacte des liaisons entre machines."
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,16" />
                                        <Button Content="Topologie simple"
                                                Click="TopologyButton_Click"
                                                HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </GroupBox>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="SynopticTab" Header="Synoptique">
                            <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderLineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Synoptique visuel"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Machines regroupées par emplacement et patchs consécutifs réunis sur un même câble."
                                               Margin="0,5,0,0"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </StackPanel>
                                <TextBlock x:Name="SynopticSummaryTextBlock"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           Text="Aucun fichier chargé." />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="410" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10"
                                        Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Emplacement de la sélection" FontWeight="SemiBold" />
                                        <Grid Grid.Row="1" Margin="0,7,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="SynopticLocationComboBox"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="True"
                                                      StaysOpenOnEdit="True"
                                                      VerticalAlignment="Center"
                                                      ToolTip="Saisissez une nouvelle zone ou choisissez une zone déjà utilisée." />
                                            <Button x:Name="ApplySynopticLocationButton"
                                                    Grid.Column="1"
                                                    Content="Affecter"
                                                    Margin="8,0,0,0"
                                                    Click="ApplySynopticLocationButton_Click"
                                                    ToolTip="Affecte cet emplacement aux machines sélectionnées." />
                                        </Grid>
                                    </Grid>
                                </Border>

                                <DataGrid x:Name="SynopticDeviceGrid"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          SelectionMode="Extended"
                                          SelectionUnit="FullRow"
                                          CellEditEnding="SynopticDeviceGrid_CellEditEnding">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Voir" Width="52">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Click="SynopticVisibilityCheckBox_Click" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Machine" Binding="{Binding DeviceName}" IsReadOnly="True" Width="1.35*" />
                                        <DataGridTextColumn Header="Emplacement" Binding="{Binding Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.25*" />
                                        <DataGridTextColumn Header="TX/RX" Binding="{Binding ChannelCount}" IsReadOnly="True" Width="72" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <Border Grid.Column="2"
                                    Background="#F7F9FC"
                                    BorderBrush="{DynamicResource BorderLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <Canvas x:Name="SynopticCanvas"
                                            Width="900"
                                            Height="560"
                                            Background="#F7F9FC" />
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ShowAllSynopticDevicesButton"
                                    Content="Tout afficher"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ShowAllSynopticDevicesButton_Click" />
                            <Button x:Name="HideSelectedSynopticDevicesButton"
                                    Grid.Column="1"
                                    Content="Masquer sélection"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="HideSelectedSynopticDevicesButton_Click" />
                            <Button x:Name="MoveSynopticDeviceUpButton"
                                    Grid.Column="2"
                                    Content="↑"
                                    Width="42"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="MoveSynopticDeviceUpButton_Click"
                                    ToolTip="Place la machine sélectionnée plus haut dans son emplacement." />
                            <Button x:Name="MoveSynopticDeviceDownButton"
                                    Grid.Column="3"
                                    Content="↓"
                                    Width="42"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="MoveSynopticDeviceDownButton_Click"
                                    ToolTip="Place la machine sélectionnée plus bas dans son emplacement." />
                            <CheckBox x:Name="OpenSynopticAfterExportCheckBox"
                                      Grid.Column="4"
                                      Content="Ouvrir après export"
                                      IsChecked="True"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,14,0" />
                            <Button x:Name="RefreshSynopticButton"
                                    Grid.Column="5"
                                    Content="Actualiser l’aperçu"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="RefreshSynopticButton_Click" />
                            <Button x:Name="ExportSynopticButton"
                                    Grid.Column="6"
                                    Content="Exporter le synoptique SVG"
                                    Click="ExportSynopticButton_Click"
                                    ToolTip="Crée un fichier vectoriel en couleur sans modifier le XML Dante." />
                            <Button x:Name="ExportSynopticPdfButton"
                                    Grid.Column="7"
                                    Content="Exporter le synoptique PDF"
                                    Click="ExportSynopticPdfButton_Click"
                                    ToolTip="Crée un PDF vectoriel en couleur sans modifier le XML Dante." />
                        </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </TabItem>

                <TabItem x:Name="HealthTab" Header="Santé du fichier">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderLineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="240" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="HealthSummaryTextBlock"
                                           Text="Aucun fichier chargé."
                                           Foreground="{DynamicResource MutedTextBrush}" />
                                <StackPanel Grid.Column="1">
                                    <Label Content="Filtre santé" />
                                    <ComboBox x:Name="HealthFilterComboBox"
                                              SelectionChanged="HealthFilter_Changed" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid x:Name="HealthIssuesGrid" Grid.Row="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Gravité" Binding="{Binding SeverityLabel}" Width="0.9*" />
                                <DataGridTextColumn Header="Catégorie" Binding="{Binding CategoryLabel}" Width="1.2*" />
                                <DataGridTextColumn Header="Device" Binding="{Binding DeviceName}" Width="1.4*" />
                                <DataGridTextColumn Header="Dante Id" Binding="{Binding DanteId}" Width="0.7*" />
                                <DataGridTextColumn Header="Canal" Binding="{Binding ChannelName}" Width="1.3*" />
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="3*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem x:Name="SafetyTab" Header="Sécurité et journal">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <WrapPanel>
                            <Button Content="Vérifier le fichier" Click="ValidateButton_Click" />
                            <Button Content="Rapport final avant Dante"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="FinalDanteCheckButton_Click"
                                    ToolTip="Affiche un résumé OK / points à vérifier avant d'importer le XML dans Dante Controller." />
                            <Button Content="Rapport compatibilité Dante Controller" Style="{StaticResource SecondaryButtonStyle}" Click="CompatibilityReportButton_Click" />
                            <Button Content="Actualiser le résumé" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshSummaryButton_Click" />
                            <Button Content="Historique actions"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ActionHistoryButton_Click"
                                    ToolTip="Affiche les dernières actions réalisées dans l'application." />
                            <Button Content="Comparer XML" Style="{StaticResource SecondaryButtonStyle}" Click="CompareXmlButton_Click" />
                            <Button Content="Quick start"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="OpenQuickStartButton_Click"
                                    ToolTip="Ouvre la notice rapide PDF." />
                            <Button Content="Notice complète"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="OpenFullNoticeButton_Click"
                                    ToolTip="Ouvre la notice complète PDF." />
                        </WrapPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SaveSummaryTextBox"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,14,0" />

                            <Border Grid.Column="1"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Journal" FontWeight="SemiBold" FontSize="16" />
                                    <ListBox x:Name="LogListBox" Grid.Row="1" Margin="0,12,0,0" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Atomic Bomb">
                    <Grid Margin="0,12,0,0">
                        <Border MaxWidth="900"
                                Padding="26"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#2B1114"
                                BorderBrush="#8B1A1A"
                                BorderThickness="2"
                                CornerRadius="6">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="GÉNÉRATEUR D'EXPÉRIENCE HORRIBLE (MAIS PÉDAGOGIQUE)"
                                           Foreground="White"
                                           FontSize="19"
                                           FontWeight="Bold"
                                           TextAlignment="Center" />
                                <TextBlock Margin="0,8,0,12"
                                           MaxWidth="780"
                                           Foreground="#FECACA"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Text="Composez le pire réseau de formation possible, sans toucher au vrai fichier. Décochez simplement ce que vous souhaitez épargner." />
                                <Border Margin="0,0,0,14"
                                        Padding="14,10"
                                        Background="#3A171B"
                                        BorderBrush="#7F1D1D"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="Que faut-il saboter ?"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center" />
                                        <UniformGrid Columns="2" Margin="0,8,0,0">
                                            <CheckBox x:Name="AtomicDeviceNamesCheckBox" Content="Noms des machines" IsChecked="True" Foreground="White" Margin="8,3" />
                                            <CheckBox x:Name="AtomicTxLabelsCheckBox" Content="Labels des canaux TX" IsChecked="True" Foreground="White" Margin="8,3" />
                                            <CheckBox x:Name="AtomicRxLabelsCheckBox" Content="Labels des canaux RX" IsChecked="True" Foreground="White" Margin="8,3" />
                                            <CheckBox x:Name="AtomicPatchesCheckBox" Content="Patchs / subscriptions" IsChecked="True" Foreground="White" Margin="8,3" />
                                            <CheckBox x:Name="AtomicNetworkModeCheckBox" Content="Modes réseau" IsChecked="True" Foreground="White" Margin="8,3" />
                                            <CheckBox x:Name="AtomicPreferredMasterCheckBox" Content="Preferred Master" IsChecked="True" Foreground="White" Margin="8,3" />
                                            <CheckBox x:Name="AtomicLatencyCheckBox" Content="Latences" IsChecked="True" Foreground="White" Margin="8,3" />
                                            <CheckBox x:Name="AtomicSampleRateCheckBox" Content="Fréquences d'échantillonnage" IsChecked="True" Foreground="White" Margin="8,3" />
                                            <CheckBox x:Name="AtomicEncodingCheckBox" Content="Bits par échantillon" IsChecked="True" Foreground="White" Margin="8,3" />
                                            <CheckBox x:Name="AtomicIpCheckBox" Content="IP principales" IsChecked="True" Foreground="White" Margin="8,3" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="AtomicChaosButton"
                                        HorizontalAlignment="Center"
                                        Content="ATOMIC BOMB"
                                        Style="{StaticResource AtomicButtonStyle}"
                                        Click="AtomicChaosButton_Click"
                                        ToolTip="Crée un exercice hors ligne en mélangeant uniquement les catégories cochées. Trois confirmations sont requises." />
                                <TextBlock Margin="0,12,0,0"
                                           Foreground="#FCA5A5"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           Text="Trois confirmations avant le chaos. Le XML original, lui, dort tranquille." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Une grille dédiée garantit que le crédit reste visible à droite.
             Le StatusBar natif compressait son dernier élément sur deux lignes. -->
        <Border Grid.Row="2"
                MinHeight="34"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderLineBrush}"
                BorderThickness="0,1,0,0"
                Padding="4,2,8,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Prêt"
                               Foreground="{DynamicResource MutedTextBrush}"
                               VerticalAlignment="Center" />
                    <Border Width="1" Height="16" Margin="7,0"
                            Background="{DynamicResource BorderLineBrush}" />
                    <TextBlock x:Name="ModeTextBlock"
                               Text="Mode : Lecture seule"
                               Foreground="{DynamicResource MutedTextBrush}"
                               VerticalAlignment="Center" />
                    <Border Width="1" Height="16" Margin="7,0"
                            Background="{DynamicResource BorderLineBrush}" />
                    <TextBlock x:Name="CountsTextBlock"
                               Text="0 device - 0 TX - 0 RX"
                               Foreground="{DynamicResource MutedTextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="By Mamat"
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextAlignment="Right"
                               Opacity="0.82" />
                    <TextBlock Text="et ses agents"
                               FontSize="8"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextAlignment="Right"
                               Opacity="0.68" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
