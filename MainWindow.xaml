<Window x:Class="DanteConfigEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dante Config Editor V3.03"
        Width="1280"
        Height="820"
        MinWidth="1120"
        MinHeight="720"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#10141F" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#171D2B" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#202838" />
        <SolidColorBrush x:Key="TextBrush" Color="#F6F8FB" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#AAB4C5" />
        <SolidColorBrush x:Key="BorderLineBrush" Color="#334057" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2F80ED" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#1D5FB8" />
        <SolidColorBrush x:Key="DangerBrush" Color="#D64545" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#2E9D62" />

        <!-- Styles globaux de l'application. Les couleurs changent via SetTheme dans MainWindow.xaml.cs. -->
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="Padding" Value="0,8,0,4" />
        </Style>

        <DataTemplate x:Key="WhiteListTextTemplate">
            <TextBlock Text="{Binding}"
                       Foreground="#111827"
                       TextWrapping="NoWrap" />
        </DataTemplate>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
        </Style>

        <!-- Les listes restent volontairement en noir sur fond blanc, même en thème sombre. -->
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="ItemTemplate" Value="{StaticResource WhiteListTextTemplate}" />
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#E5E7EB" />
                    <Setter Property="Foreground" Value="#111827" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E5E7EB" />
                    <Setter Property="Foreground" Value="#111827" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemTemplate" Value="{StaticResource WhiteListTextTemplate}" />
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6" />
                    <Setter Property="Foreground" Value="#111827" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E5E7EB" />
                    <Setter Property="Foreground" Value="#111827" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,8,0,8" />
        </Style>

        <Style TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,6,12,6" />
        </Style>

        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AutoGenerateColumns" Value="False" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Barre haute : actions de fichier, état du document et changement de thème. -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderLineBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Ouvrir XML" Click="OpenButton_Click" />
                    <Button Content="Enregistrer sous" Click="SaveAsButton_Click" />
                    <Button x:Name="UndoLastButton" Content="Annuler action" Style="{StaticResource SecondaryButtonStyle}" Click="UndoLastButton_Click" IsEnabled="False" />
                    <Button Content="Annuler les changements" Style="{StaticResource SecondaryButtonStyle}" Click="RevertButton_Click" />
                    <ComboBox x:Name="RecentFilesComboBox"
                              Width="230"
                              Margin="0,0,8,8" />
                    <Button Content="Ouvrir récent" Style="{StaticResource SecondaryButtonStyle}" Click="OpenRecentButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,18,0" VerticalAlignment="Center">
                    <TextBlock Text="Dante Config Editor V3.03" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Name="FilePathTextBlock"
                               Text="Aucun fichier ouvert"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="DirtyStateTextBlock"
                               Text="Non modifié"
                               Margin="0,0,14,8"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedTextBrush}" />
                    <ToggleButton x:Name="ThemeToggleButton"
                                  Content="Thème clair"
                                  Checked="ThemeToggleButton_Checked"
                                  Unchecked="ThemeToggleButton_Unchecked" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Corps principal : navigation à gauche, onglets de travail à droite. -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderLineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Projet" FontWeight="SemiBold" FontSize="15" />
                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderLineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,10,0,0">
                        <TextBlock x:Name="ProjectSummaryTextBlock"
                                   Text="Chargez un fichier XML pour commencer."
                                   Foreground="{DynamicResource MutedTextBrush}" />
                        </Border>

                        <TextBlock Text="Recherche"
                                   FontWeight="SemiBold"
                                   Margin="0,18,0,6" />
                        <TextBox x:Name="GlobalSearchTextBox"
                                 TextChanged="GlobalSearchTextBox_TextChanged" />
                        <ListBox x:Name="GlobalSearchListBox"
                                 Height="170"
                                 Margin="0,8,0,0"
                                 SelectionChanged="GlobalSearchListBox_SelectionChanged" />
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom"
                            Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderLineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10">
                        <TextBlock Text="Mode hors ligne : l'application modifie uniquement les fichiers XML chargés. Elle ne se connecte pas au réseau Dante." 
                                   Foreground="{DynamicResource MutedTextBrush}" />
                    </Border>
                </DockPanel>
            </Border>

            <TabControl x:Name="MainTabs"
                        Grid.Column="1"
                        Margin="16"
                        Background="Transparent"
                        BorderThickness="0">
                <TabItem Header="Configuration">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderLineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock x:Name="ConfigSummaryTextBlock"
                                           Text="Aucun fichier chargé."
                                           Foreground="{DynamicResource MutedTextBrush}" />
                                <Border x:Name="ImportantWarningsBorder"
                                        Background="#FEF2F2"
                                        BorderBrush="{DynamicResource DangerBrush}"
                                        BorderThickness="2"
                                        CornerRadius="6"
                                        Padding="12"
                                        Margin="0,10,0,0"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="POINTS À VÉRIFIER"
                                                   Foreground="#991B1B"
                                                   FontWeight="Bold"
                                                   FontSize="16" />
                                        <TextBlock x:Name="ImportantWarningsTextBlock"
                                                   Foreground="#991B1B"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>

                                <GroupBox Header="Machine sélectionnée" Margin="0,0,12,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.ColumnSpan="2">
                                            <Label Content="Machine" />
                                            <ComboBox x:Name="DeviceComboBox" SelectionChanged="DeviceComboBox_SelectionChanged" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Margin="0,8,8,0">
                                            <Label Content="Nouveau nom" />
                                            <TextBox x:Name="NewNameTextBox" />
                                            <Button Content="Changer le nom" Click="ApplyRenameButton_Click" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,8,0,0">
                                            <Label Content="Mode réseau" />
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="RedundantRadioButton" Content="Redondant" GroupName="NetworkMode" />
                                                <RadioButton x:Name="DaisychainRadioButton" Content="Daisychain" GroupName="NetworkMode" />
                                            </StackPanel>
                                            <Button Content="Changer le mode" Click="ApplyNetworkButton_Click" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Margin="0,8,8,0">
                                            <Label Content="Latence unicast" />
                                            <ComboBox x:Name="LatencyComboBox" />
                                            <Button Content="Changer la latence" Click="ApplyLatencyButton_Click" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,8,0,0">
                                            <Label Content="Horloge" />
                                            <CheckBox x:Name="PreferredMasterCheckBox" Content="Preferred master" />
                                            <Button Content="Changer preferred master" Click="ApplyPreferredMasterButton_Click" />
                                        </StackPanel>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Grid.Column="1" Header="Canaux de la machine" Margin="0,0,12,0">
                                    <StackPanel>
                                        <Label Content="Canal à renommer" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="ChannelKindComboBox"
                                                      SelectionChanged="ChannelSelector_Changed"
                                                      Margin="0,0,8,0" />
                                            <ComboBox x:Name="ChannelComboBox"
                                                      Grid.Column="1"
                                                      SelectionChanged="ChannelComboBox_SelectionChanged" />
                                        </Grid>

                                        <Label Content="Nouveau nom de canal" />
                                        <TextBox x:Name="NewChannelNameTextBox" />
                                        <WrapPanel>
                                            <Button Content="Renommer le canal" Click="RenameChannelButton_Click" />
                                            <Button Content="Réinitialiser les canaux de la machine" Style="{StaticResource SecondaryButtonStyle}" Click="ResetDeviceChannelsButton_Click" />
                                        </WrapPanel>
                                        <Separator Margin="0,6,0,6" />
                                        <TextBlock Text="Renommage en série" FontWeight="SemiBold" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,8,0">
                                                <Label Content="Canal début" />
                                                <ComboBox x:Name="BatchRenameStartChannelComboBox" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <Label Content="Canal fin" />
                                                <ComboBox x:Name="BatchRenameEndChannelComboBox" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="90" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,8,0">
                                                <Label Content="Préfixe" />
                                                <TextBox x:Name="BatchRenamePrefixTextBox" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <Label Content="Numéro" />
                                                <TextBox x:Name="BatchRenameStartTextBox" Text="1" />
                                            </StackPanel>
                                        </Grid>
                                        <Button Content="Renommer la série" Style="{StaticResource SecondaryButtonStyle}" Click="BatchRenameButton_Click" />
                                    </StackPanel>
                                </GroupBox>

                                <StackPanel Grid.Column="2">
                                    <GroupBox Header="Actions globales">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="GlobalRedundantRadioButton" Content="Redondant" GroupName="GlobalNetworkMode" />
                                                <RadioButton x:Name="GlobalDaisychainRadioButton" Content="Daisychain" GroupName="GlobalNetworkMode" />
                                            </StackPanel>
                                            <Button Content="Appliquer le mode à tous" Click="ApplyAllNetworkButton_Click" />

                                            <Label Content="Latence globale" />
                                            <ComboBox x:Name="GlobalLatencyComboBox" />
                                            <Button Content="Appliquer la latence à tous" Click="ApplyAllLatencyButton_Click" />

                                            <CheckBox x:Name="GlobalPreferredMasterCheckBox" Content="Preferred master pour tous" />
                                            <Button Content="Appliquer preferred master à tous" Click="ApplyAllPreferredMasterButton_Click" />

                                            <Button Content="Réinitialiser tous les canaux" Style="{StaticResource SecondaryButtonStyle}" Click="ResetAllChannelsButton_Click" />
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Header="Listes rapides">
                                        <WrapPanel>
                                            <Button Content="Redondants" Style="{StaticResource SecondaryButtonStyle}" Click="ListRedundantButton_Click" />
                                            <Button Content="Daisychain" Style="{StaticResource SecondaryButtonStyle}" Click="ListDaisychainButton_Click" />
                                            <Button Content="Latences" Style="{StaticResource SecondaryButtonStyle}" Click="ListLatenciesButton_Click" />
                                            <Button Content="Preferred masters" Style="{StaticResource SecondaryButtonStyle}" Click="ListPreferredMastersButton_Click" />
                                        </WrapPanel>
                                    </GroupBox>
                                </StackPanel>
                            </Grid>

                            <DataGrid x:Name="DeviceGrid" Grid.Row="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Device" Binding="{Binding Name}" Width="2*" />
                                    <DataGridTextColumn Header="Friendly name" Binding="{Binding FriendlyName}" Width="2*" />
                                    <DataGridTextColumn Header="Réseau" Binding="{Binding NetworkMode}" Width="*" />
                                    <DataGridTextColumn Header="Latence" Binding="{Binding Latency}" Width="*" />
                                    <DataGridCheckBoxColumn Header="Preferred" Binding="{Binding PreferredMaster, Mode=OneWay}" Width="*" />
                                    <DataGridTextColumn Header="TX" Binding="{Binding TxCount}" Width="0.7*" />
                                    <DataGridTextColumn Header="RX" Binding="{Binding RxCount}" Width="0.7*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Patch">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="245" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.RowSpan="3"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderLineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,14,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Filtre émetteur TX" FontWeight="SemiBold" />
                                <ListBox x:Name="SenderDeviceList"
                                         Grid.Row="1"
                                         SelectionChanged="SenderDeviceList_SelectionChanged"
                                         Margin="0,8,0,16" />

                                <TextBlock Grid.Row="2" Text="Filtre récepteur RX" FontWeight="SemiBold" />
                                <ListBox x:Name="ReceiverDeviceList"
                                         Grid.Row="3"
                                         SelectionChanged="ReceiverDeviceList_SelectionChanged"
                                         Margin="0,8,0,0" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderLineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.35*" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Label Content="Recherche device ou canal" />
                                <Label Grid.Column="1" Content="Source TX à appliquer" />
                                <Label Grid.Column="2" Content="Canal TX à appliquer" />

                                <TextBox x:Name="PatchSearchTextBox"
                                         Grid.Row="1"
                                         TextChanged="PatchFilter_Changed"
                                         Margin="0,0,8,0" />
                                <ComboBox x:Name="SourceDeviceComboBox"
                                          Grid.Row="1"
                                          Grid.Column="1"
                                          SelectionChanged="SourceDeviceComboBox_SelectionChanged"
                                          Margin="0,0,8,0" />
                                <ComboBox x:Name="SourceChannelComboBox"
                                          Grid.Row="1"
                                          Grid.Column="2"
                                          SelectionChanged="SourceChannelComboBox_SelectionChanged"
                                          Margin="0,0,8,0" />
                                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal">
                                    <Button Content="Appliquer" Click="ApplyPatchButton_Click" />
                                    <Button Content="Supprimer" Style="{StaticResource SecondaryButtonStyle}" Click="RemovePatchButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid x:Name="PatchGrid"
                                  Grid.Column="1"
                                  Grid.Row="1"
                                  SelectionChanged="PatchGrid_SelectionChanged">
                            <DataGrid.RowStyle>
                                <Style TargetType="{x:Type DataGridRow}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RowState}" Value="Conflict">
                                            <Setter Property="Background" Value="#7F1D1D" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RowState}" Value="Modified">
                                            <Setter Property="Background" Value="#3B2F12" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="RX device" Binding="{Binding RxDevice}" Width="1.4*" />
                                <DataGridTextColumn Header="RX canal" Binding="{Binding RxChannelName}" Width="1*" />
                                <DataGridTextColumn Header="TX device" Binding="{Binding TxDevice}" Width="1.4*" />
                                <DataGridTextColumn Header="TX canal" Binding="{Binding TxChannelName}" Width="1*" />
                                <DataGridCheckBoxColumn Header="Actif" Binding="{Binding IsActive, Mode=OneWay}" Width="0.7*" />
                                <DataGridCheckBoxColumn Header="Modifié" Binding="{Binding IsModified, Mode=OneWay}" Width="0.8*" />
                                <DataGridTextColumn Header="État" Binding="{Binding Status}" Width="1.5*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Column="1" Grid.Row="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="ConflictsOnlyCheckBox"
                                      Content="Afficher seulement les conflits"
                                      Checked="PatchFilter_Changed"
                                      Unchecked="PatchFilter_Changed"
                                      Margin="0,0,18,0"
                                      VerticalAlignment="Center" />
                            <GroupBox Grid.Column="1" Header="Renommer le RX sélectionné" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PatchRxRenameChannelTextBox"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Content="Renommer RX" Style="{StaticResource SecondaryButtonStyle}" Click="RenamePatchRxChannelButton_Click" />
                                </Grid>
                            </GroupBox>
                            <GroupBox Grid.Column="2" Header="Renommer le TX source" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PatchTxRenameChannelTextBox"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Content="Renommer TX" Style="{StaticResource SecondaryButtonStyle}" Click="RenamePatchTxChannelButton_Click" />
                                </Grid>
                            </GroupBox>
                            <TextBlock x:Name="PatchSummaryTextBlock"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Sécurité et journal">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Vérifier le fichier" Click="ValidateButton_Click" />
                            <Button Content="Actualiser le résumé" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshSummaryButton_Click" />
                            <Button Content="Exporter TXT" Style="{StaticResource SecondaryButtonStyle}" Click="ExportTxtButton_Click" />
                            <Button Content="Exporter PDF" Style="{StaticResource SecondaryButtonStyle}" Click="ExportPdfButton_Click" />
                            <Button Content="Comparer XML" Style="{StaticResource SecondaryButtonStyle}" Click="CompareXmlButton_Click" />
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SaveSummaryTextBox"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,14,0" />

                            <Border Grid.Column="1"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Journal" FontWeight="SemiBold" FontSize="16" />
                                    <ListBox x:Name="LogListBox" Grid.Row="1" Margin="0,12,0,0" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <StatusBar Grid.Row="2"
                   Background="{DynamicResource SurfaceBrush}"
                   BorderBrush="{DynamicResource BorderLineBrush}"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Prêt" Foreground="{DynamicResource MutedTextBrush}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="CountsTextBlock" Text="0 device - 0 TX - 0 RX" Foreground="{DynamicResource MutedTextBrush}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="By Mamat" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Opacity="0.72" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
