<Window x:Class="DanteConfigEditor.DeviceDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Détail machine"
        Width="920"
        Height="720"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="{x:Type Label}">
            <Setter Property="Padding" Value="0,8,0,4" />
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Padding" Value="8,5" />
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Padding" Value="6,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Text="Détail machine"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Identité et formats">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,8,0">
                            <Label Content="Nom machine" />
                            <TextBox x:Name="DeviceNameTextBox" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <Label Content="Mode réseau" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RedundantRadioButton" Content="Redondant" GroupName="DeviceNetworkMode" Margin="0,6,12,0" />
                                <RadioButton x:Name="DaisychainRadioButton" Content="Daisychain" GroupName="DeviceNetworkMode" Margin="0,6,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="Horloge" />
                            <CheckBox x:Name="PreferredMasterCheckBox" Content="Preferred master" Margin="0,6,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,8,8,0">
                            <Label Content="Latence unicast" />
                            <ComboBox x:Name="LatencyComboBox" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,8,8,0">
                            <Label Content="Sample rate" />
                            <ComboBox x:Name="SampleRateComboBox" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,8,0,0">
                            <Label Content="Bits par échantillon" />
                            <ComboBox x:Name="EncodingComboBox" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Adresse IP">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Label Content="Mode IP" Margin="0,0,18,0" />
                            <RadioButton x:Name="IpAutoRadioButton"
                                         Content="Automatique"
                                         GroupName="IpMode"
                                         Checked="IpModeRadioButton_Checked"
                                         Margin="0,8,0,0" />
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="105" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <RadioButton x:Name="IpStaticRadioButton"
                                         Content="Fixe"
                                         GroupName="IpMode"
                                         Checked="IpModeRadioButton_Checked"
                                         Margin="0,34,12,0" />

                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <Label Content="Adresse IP" />
                                <TextBox x:Name="IpAddressTextBox" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <Label Content="Masque" />
                                <TextBox x:Name="IpNetmaskTextBox" />
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <Label Content="Passerelle" />
                                <TextBox x:Name="IpGatewayTextBox" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Canaux">
                    <TabControl Margin="8">
                        <TabItem Header="TX">
                            <DataGrid x:Name="TxChannelsGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      MinHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Index}" IsReadOnly="True" Width="70" />
                                    <DataGridTextColumn Header="Nom" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="RX">
                            <DataGrid x:Name="RxChannelsGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      MinHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Index}" IsReadOnly="True" Width="70" />
                                    <DataGridTextColumn Header="Nom" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem x:Name="PatchTab" Header="Patch RX">
                            <Grid Margin="16" MinHeight="220">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="PatchDescriptionTextBlock"
                                           Text="Affectez des canaux TX disponibles aux entrées RX de cette machine."
                                           TextWrapping="Wrap" />
                                <Button x:Name="OpenPatchWorkspaceButton"
                                        Grid.Row="1"
                                        Content="Ouvrir l'atelier de patch"
                                        HorizontalAlignment="Left"
                                        Margin="0,14,0,0"
                                        Click="OpenPatchWorkspaceButton_Click" />
                                <TextBlock x:Name="PatchSummaryTextBlock"
                                           Grid.Row="2"
                                           Text="Aucun changement de patch en attente."
                                           Foreground="#64748B"
                                           TextWrapping="Wrap"
                                           Margin="0,14,0,0" />
                                <TextBlock x:Name="PatchSafetyTextBlock"
                                           Grid.Row="3"
                                           Text="Les changements de patch seront appliqués avec les autres réglages de cette fenêtre."
                                           Foreground="#64748B"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Bottom"
                                           Margin="0,14,0,0" />
                            </Grid>
                        </TabItem>
                    </TabControl>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="Les changements seront appliqués au XML après validation."
                       VerticalAlignment="Center"
                       Foreground="#64748B" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annuler" IsCancel="True" Click="CancelButton_Click" />
                <Button Content="Appliquer" IsDefault="True" Click="ApplyButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
